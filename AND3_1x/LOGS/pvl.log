DEVICE mimcap_1p0_sin capm2_1p0_ud ctm ( TOP ) metal2 ( BOT ) -element X -model mimcap_1p0_sin [ 
 property lt , wt 
 A_CAP = area ( capm2_1p0_ud ) 
 P_CAP = perimeter ( capm2_1p0_ud ) 
 P_2_CAP = P_CAP * P_CAP 
 AC4 = A_CAP * 16 
