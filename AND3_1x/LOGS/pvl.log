    DEVICE mimcap_1p0_sin capm2_1p0_udc ctm( TOP) metal2( BOT) -element X -model mimcap_1p0_sin [
		A_CAP = area(capm2_1p0_udc)
		P_CAP = perim(capm2_1p0_udc)
		P_2_CAP = (P_CAP * P_CAP)
		AC4 = (A_CAP * 16)
		KKK = (P_2_CAP - AC4)
		if (KKK < 0)
    		KKK = 0
		SQ = sqrt(KKK)
		lt = ((P_CAP + SQ) / 4)
		wt = ((P_CAP - SQ) / 4)
	]

