RULE floating.psub_float {
    CAPTION psub_float is not connected to GROUND;
    PATHCHK psub_float -ground not -ports_also -outputlayer no_ground_path;
    SELECT_NET psub_float AVD33 AVD33B AVD33G AVD33R AVD33WELL AVDD AVDDB AVDDBG AVDDG AVDDR AVDWELL DVDD TAVD33 TAVD33PST TAVDD TAVDDPST TVDD VD33 VD33WELL VDD VDD5V VDDESD VDDG VDDM VDDPST VDDSA VDWELL -output direct_connect_power;
    OR no_ground_path direct_connect_power ; // -outputlayer _EPTMPL266732
}
SELECT_NET gate_lv_not_IO1 AGND AVS33 AVS33B AVS33G AVS33R AVS33SUB AVSS AVSSB AVSSBG AVSSG AVSSR AVSSUB DVSS GND TACVSS TAVSS TAVSSPST TVSS VS33 VS33SUB VSS VSSESD VSSG VSSM VSSPST VSSUB -OUTPUT gate_lv_GND;

RULE npvss49 {
    CAPTION ntap connected to GROUND;
    OR VARDMYX VARG3 -outputlayer npvss49_0;
    OR VARG6 npvss49_0 -outputlayer npvss49_1;
    OR JVARD npvss49_1 -outputlayer npvss49_2;
    NOT ntap npvss49_2 -outputlayer ntap_not_var;
    SELECT_NET ntap_not_var AGND AVS33 AVS33B AVS33G AVS33R AVS33SUB AVSS AVSSB AVSSBG AVSSG AVSSR AVSSUB DVSS GND TACVSS TAVSS TAVSSPST TVSS VS33 VS33SUB VSS VSSESD VSSG VSSM VSSPST VSSUB;
}
