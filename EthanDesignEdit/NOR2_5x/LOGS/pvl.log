SIZE GATE_NP -by 0.03 -outputlayer _EPTMPL262260;
AND _EPTMPL262260 POLY -outputlayer _EPTMPL262261;
SIZE _EPTMPL262261 -by "NP_C_5" -outputlayer EXGATE_NP;
SIZE GATE_PP -by 0.03 -outputlayer _EPTMPL262263;
AND _EPTMPL262263 POLY -outputlayer _EPTMPL262264;
SIZE _EPTMPL262264 -by "PP_C_5" -outputlayer EXGATE_PP;
OR CB FW -outputlayer _EPTMPL262266;
OR _EPTMPL262266 LW -outputlayer FUSE_LMARK;
NOT PMDMY FUSE_LMARK -outputlayer RNGX;
COPY CHIPx -outputlayer CHIP_CORE;
OR CB CBD -outputlayer _EPTMPL262270;
HOLES _EPTMPL262270 -outputlayer PADH;
SELECT -inside CHIP_CORE PADH -outputlayer SCORE;
SELECT -interact CHIP SCORE -outputlayer SR_CHIP;
SIZE SR_CHIP -by -10 -outputlayer _EPTMPL262274;
NOT SR_CHIP _EPTMPL262274 -outputlayer SR;
OR SR SEALRING -outputlayer SEALRING_ALL;
AND CB SR -outputlayer SR_CB;
AND CO SR -outputlayer SR_CO;
AND VIA1 SR -outputlayer SR_VIA1;
AND VIA2 SR -outputlayer SR_VIA2;
AND M1 SR -outputlayer SR_M1;
AND M2 SR -outputlayer SR_M2;
AND M3 SR -outputlayer SR_M3;
SELECT -interact CHIPx SCORE -outputlayer CHIP_WISR;
NOT CHIP_WISR SCORE -outputlayer SR_EDGE;
SELECT -interact -not CHIPx SR_EDGE -outputlayer CHIP_NOSR;
COPY CHIP_NOSR -outputlayer CHIP_NOSR1;
COPY CHIP_NOSR -outputlayer CHIP_NOSR2;
COPY CHIP_NOSR -outputlayer CHIP_NOSR3;
COPY SR_EDGE -outputlayer SR_EDGE1;
COPY SR_EDGE -outputlayer SR_EDGE2;
COPY SR_EDGE -outputlayer SR_EDGE3;
AND VIAD SR -outputlayer SR_VIAD;
AND OD SBDDMY -outputlayer _EPTMPL262294;
AND _EPTMPL262294 NWEL -outputlayer SBDOD;
SELECT -interact NWEL SBDOD -outputlayer NW_SBD;
SELECT -interact DNW SBDOD -outputlayer DNW_SBD;
SELECT -interact PP SBDOD -outputlayer PP_SBD;
HOLES PP_SBD -inner -outputlayer PP_SBD_HOLE;
OR PP_SBD PP_SBD_HOLE -outputlayer PP_SBD_ALL;
NOT PP PP_SBD -outputlayer PP_NSBD;
SELECT -interact SBDOD PP -outputlayer PPOD_SBD;
AND SBDOD NP -outputlayer NPOD_SBD;
EDGE_EXPAND PPOD_SBD -outside_by 0.48 -outputlayer PPOD_SBD_GAP;
SELECT -touch PPOD_SBD_GAP NPOD_SBD -outputlayer PPOD_SBD_G;
EDGE_EXPAND NPOD_SBD -outside_by 0.48 -outputlayer NPOD_SBD_GAP;
SELECT -touch NPOD_SBD_GAP PPOD_SBD -outputlayer NPOD_SBD_G;
OR PPOD_SBD NPOD_SBD -outputlayer _EPTMPL262308;
OR _EPTMPL262308 PPOD_SBD_G -outputlayer SBDOD_ALL;
EDGE_SELECT -coincident_only -outside PPOD_SBD NPOD_SBD_G -outputlayer PPOD_SBD_W;
EDGE_SELECT -coincident_only -outside -not PPOD_SBD NPOD_SBD_G -outputlayer PPOD_SBD_L;
EDGE_SELECT -coincident_only -outside NPOD_SBD PPOD_SBD_G -outputlayer NPOD_SBD_W;
MERGE CHIP -outputlayer CHIPx;
CONNECT NTAPi NWELi;
CONNECT PTAPi RWi;
CONNECT PTAPi PWELi;
CONNECT NTAPi PSDi;
CONNECT PTAPi NSDi;
CONNECT M1xd ILP1i NTAPi PTAPi PSDi NSDi -by COi;
CONNECT M2xd M0i -by SICR_V1i;
CONNECT M1xd M2xd -by VIA1i;
CONNECT M3xd CTM2i CMM2i M2xd -by VIA2i;
CONNECT M3xd MDxd -by VIADi;

RULE HRI.WARN {
    CAPTION "RLPPDMY overlap OD is not allowed";
    AND RLPPDMY OD ; // -outputlayer _EPTMPL262324
}
AND NWEL HOTWL -outputlayer _EPTMPL262325;
OR _EPTMPL262325 RNWEL -outputlayer HOT_NWEL;
SELECT -outside -not NWEL OD2 -outputlayer NW_5V;
SELECT -outside NWEL OD2 -outputlayer NW_1_8V;

RULE NW.W.1 {
    CAPTION "Min. NWEL width < 0.86";
    INTE NWEL -lt 0.86 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262329
}

RULE NW.W.2 {
    CAPTION "Min. HOT_NWEL width < 2.10";
    INTE HOT_NWEL -lt 2.1 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262330
}

RULE NW.S.1 {
    CAPTION "Min. different potential NWEL space < 1.40";
    STAMP NWEL NWELi -outputlayer NWEL_NODAL;
    EXTE NWEL_NODAL -lt 1.4 -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL262332
    EXTE RNWEL NWEL -lt 1.4 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262333
    EXTE RNWEL -lt 1.4 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262334
}

RULE NW.S.2 {
    CAPTION "Min. same potential NWEL space < 0.6";
    EXTE NWEL -lt 0.6 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262335
}

RULE NW.R.3 {
    CAPTION "NW ABUT RWDMY from outside is not allowed";
    EDGE_BOOLEAN -coincident_only -outside NWELi RWDMY ; // -outputlayer _EPTMPL262336
}
SELECT -interact RNWEL RPO -outputlayer NWRES;
SELECT -interact OD NWRES -outputlayer ODWR;
SELECT -interact NP NWRES -outputlayer NPWR;
SELECT -interact CO_DIFF NWRES -outputlayer COWR;
NOT ODWR RPO -outputlayer RHWR;
HOLES RPO -inner -outputlayer RPONWR_H;

RULE NWR.E.1 {
    CAPTION "Min. OD enclose NWEL resistor < 1.0";
    ENC NWRES ODWR -lt 1 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262343
    SELECT -cut NWRES ODWR ; // -outputlayer _EPTMPL262344
}

RULE NWR.E.2 {
    CAPTION "Min. NWEL resistor enclose CO < 0.3";
    ENC COWR NWRES -lt 0.3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262345
    SELECT -cut COWR NWRES ; // -outputlayer _EPTMPL262346
}

RULE NWR.C.1 {
    CAPTION "Min. RPO hole enclose NWEL < 0.3";
    ENC NWRES RHWR -lt 0.3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262347
}

RULE NWR.C.2 {
    CAPTION "Min. RPO enclose OD (with NWEL resistor) < 0.22";
    ENC ODWR RPO -lt 0.22 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262348
}

RULE NWR.C.3 {
    CAPTION "Min. RPO hole enclose NWEL resistor CO < 0.3";
    ENC COWR RHWR -lt 0.3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262349
    SELECT -cut COWR RHWR ; // -outputlayer _EPTMPL262350
}

RULE NWR.O.1 {
    CAPTION "Min. RPO overlap NP < 0.4";
    INTE NPWR RPO -lt 0.4 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262351
    SELECT -interact RPO NWRES -outputlayer X;
    HOLES X -inner -outputlayer H;
    NOT H NPWR ; // -outputlayer _EPTMPL262354
}

RULE NWR.R.1 {
    CAPTION "NW resistor doped by implants not allowed.";
    AND RWDMY NPOD ; // -outputlayer _EPTMPL262355
    AND RWDMY PPOD ; // -outputlayer _EPTMPL262356
}
SELECT -interact NTAPu NWRES -outputlayer NWT;
SELECT -interact CBu VDD_VSS_DUMMY -outputlayer NWT_CB_DUMMY;
SELECT -interact UBMnu VDD_VSS_DUMMY -outputlayer NWT_UBMn_DUMMY;
SELECT -interact UBMdu VDD_VSS_DUMMY -outputlayer NWT_UBMd_DUMMY;
SELECT -label "M1u" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer M1_PIN_TEXT -primary_only -outputlayer PWR_M1u_BY_TEXT;
SELECT -label "M1u" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer M1_PIN_TEXT -primary_only -outputlayer GND_M1u_BY_TEXT;
SELECT -label "M1u" -textname "?" -textlayer M1_PIN_TEXT -primary_only -outputlayer PAD_M1u_BY_TEXT;
SELECT -label "M1k" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer M1_PIN_TEXT -primary_only -outputlayer PWR_M1k_BY_TEXT;
SELECT -label "M1k" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer M1_PIN_TEXT -primary_only -outputlayer GND_M1k_BY_TEXT;
SELECT -label "M1k" -textname "?" -textlayer M1_PIN_TEXT -primary_only -outputlayer PAD_M1k_BY_TEXT;
NOT PAD_M1k_BY_TEXT PWR_M1k_BY_TEXT -outputlayer _EPTMPL262367;
NOT _EPTMPL262367 GND_M1k_BY_TEXT -outputlayer IO_PAD_M1k_BY_TEXT;
SELECT -label "M2u" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer M2_PIN_TEXT -primary_only -outputlayer PWR_M2u_BY_TEXT;
SELECT -label "M2u" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer M2_PIN_TEXT -primary_only -outputlayer GND_M2u_BY_TEXT;
SELECT -label "M2u" -textname "?" -textlayer M2_PIN_TEXT -primary_only -outputlayer PAD_M2u_BY_TEXT;
SELECT -label "M2k" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer M2_PIN_TEXT -primary_only -outputlayer PWR_M2k_BY_TEXT;
SELECT -label "M2k" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer M2_PIN_TEXT -primary_only -outputlayer GND_M2k_BY_TEXT;
SELECT -label "M2k" -textname "?" -textlayer M2_PIN_TEXT -primary_only -outputlayer PAD_M2k_BY_TEXT;
NOT PAD_M2k_BY_TEXT PWR_M2k_BY_TEXT -outputlayer _EPTMPL262375;
NOT _EPTMPL262375 GND_M2k_BY_TEXT -outputlayer IO_PAD_M2k_BY_TEXT;
SELECT -label "M3u" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer M3_PIN_TEXT -primary_only -outputlayer PWR_M3u_BY_TEXT;
SELECT -label "M3u" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer M3_PIN_TEXT -primary_only -outputlayer GND_M3u_BY_TEXT;
SELECT -label "M3u" -textname "?" -textlayer M3_PIN_TEXT -primary_only -outputlayer PAD_M3u_BY_TEXT;
SELECT -label "M3k" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer M3_PIN_TEXT -primary_only -outputlayer PWR_M3k_BY_TEXT;
SELECT -label "M3k" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer M3_PIN_TEXT -primary_only -outputlayer GND_M3k_BY_TEXT;
SELECT -label "M3k" -textname "?" -textlayer M3_PIN_TEXT -primary_only -outputlayer PAD_M3k_BY_TEXT;
NOT PAD_M3k_BY_TEXT PWR_M3k_BY_TEXT -outputlayer _EPTMPL262383;
NOT _EPTMPL262383 GND_M3k_BY_TEXT -outputlayer IO_PAD_M3k_BY_TEXT;
SELECT -label "MDu" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer MD_PIN_TEXT -primary_only -outputlayer PWR_MDu_BY_TEXT;
SELECT -label "MDu" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer MD_PIN_TEXT -primary_only -outputlayer GND_MDu_BY_TEXT;
SELECT -label "MDu" -textname "?" -textlayer MD_PIN_TEXT -primary_only -outputlayer PAD_MDu_BY_TEXT;
SELECT -label "MDk" -textname " AVDDBG   AVDDR   AVDWELL   VDWELL   VD33APST   VDD5V   TAVD33   VD33PST   AVDD   TAVDD   TAVD33PST   TAVDDPST   AVD33B   VDD   AVD33G   DVDD   AVDDG   AVDDB   VDDG   VDDPST   VD33REF   VD33   AVD33R   VDDSA " -textlayer MD_PIN_TEXT -primary_only -outputlayer PWR_MDk_BY_TEXT;
SELECT -label "MDk" -textname " VSSPST   AVS33R   AVSSUB   VSSREF   VSSAPST   VS33APST   DVSS   AVS33G   AVSSBG   TAVSS   AVS33B   AVSSB   GND   VSSG   VSSUB   VSS   AVSS   TAVSSPST   AGND   AVSSR   AVSSG " -textlayer MD_PIN_TEXT -primary_only -outputlayer GND_MDk_BY_TEXT;
SELECT -label "MDk" -textname "?" -textlayer MD_PIN_TEXT -primary_only -outputlayer PAD_MDk_BY_TEXT;
ANTENNA NWT CBu UBMnu UBMdu -gt 0 -expr "  !!AREA(CBu) + !! AREA(UBMnu) + !! AREA(UBMdu)  " -outputlayer NWT_IOPAD;
ANTENNA NWT -over NWT_CB_DUMMY NWT_UBMn_DUMMY NWT_UBMd_DUMMY -gt 0 -outputlayer NWT_VDD_VSS_PAD_DUMMY;
ANTENNA NWT -over PAD_M1u_BY_TEXT PAD_M2u_BY_TEXT PAD_M3u_BY_TEXT -gt 0 -outputlayer NWT_PAD_TEXT;
ANTENNA NWT -over PWR_M1u_BY_TEXT PWR_M2u_BY_TEXT PWR_M3u_BY_TEXT GND_M1u_BY_TEXT GND_M2u_BY_TEXT GND_M3u_BY_TEXT -gt 0 -outputlayer NWT_VDD_VSS_PAD_TEXT;
NOT NWT_IOPAD NWT_VDD_VSS_PAD_DUMMY -outputlayer NWT_IO;

RULE NWR.R.3 {
    CAPTION "Only one NW inside NWROD is allowed in one OD.";
    AND NWRES ODWR -outputlayer _EPTMPL262396;
    SELECT -interact ODWR _EPTMPL262396 -gt 1 -outputlayer A;
    SELECT -interact NWRES A ; // -outputlayer _EPTMPL262398
}

RULE NWR.R.4 {
    CAPTION "Only two NPS in NWROD is allowed in one od.";
    SELECT -interact NP NWRES -outputlayer _EPTMPL262399;
    SELECT -interact ODWR _EPTMPL262399 -ne 2 -outputlayer C;
    SELECT -interact NP C ; // -outputlayer _EPTMPL262401
    SELECT -interact NP NWRES -outputlayer _EPTMPL262402;
    SELECT -interact -not ODWR _EPTMPL262402 ; // -outputlayer _EPTMPL262403
}

RULE NWR.R.5 {
    CAPTION "ONLY TWO RPO HOLES IN NWROD ARE ALLOWED.";
    SELECT -interact ODWR RPONWR_H -ne 2 -outputlayer A;
    SELECT -interact -not ODWR RPONWR_H -outputlayer D;
    OR A D -outputlayer _EPTMPL262406;
    SELECT -interact RPONWR_H _EPTMPL262406 ; // -outputlayer _EPTMPL262407
}

RULE NWR.R.6 {
    CAPTION "For U-shape or S-shape NWROD, both OD and NW must be U-shape or S-shape and the OD edge must be";
    CAPTION "parallel to the NW edge. DRC can only flag the pattern without OD space while 2 edges of NW";
    CAPTION "[NW space or notch <= 5 um] parallel length > 0 um";
    EXTE NWRES -lt 5 -metric opposite -output region -notch only -outputlayer _EPTMPL262408;
    NOT _EPTMPL262408 NWRES -outputlayer A;
    SELECT -inside A ODWR ; // -outputlayer _EPTMPL262410
}
SELECT -interact -not RNWEL RPO -outputlayer NWRES_STI;
SELECT -interact OD NWRES_STI -outputlayer ODWR_STI;
SELECT -interact NP NWRES_STI -outputlayer NPWR_STI;

RULE NWR.E.3 {
    CAPTION "Min. extension of NP to OD (NWEL resistor under STI) 0.18 um";
    ENC ODWR_STI NPWR_STI -lt 0.18 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262414
    NOT ODWR_STI NPWR_STI ; // -outputlayer _EPTMPL262415
}
SELECT -outside -not OD NTN -outputlayer NTN_OD;
AND POLY NTN -outputlayer NTN_PO;
AND NTN_PO NTN_OD -outputlayer NTN_GATE;
EDGE_BOOLEAN -inside NTN_PO NTN_OD -outputlayer NTN_GATE_W;
EDGE_BOOLEAN -inside NTN_OD NTN_PO -outputlayer NTN_GATE_L;
OR CO OD -outputlayer _EPTMPL262421;
SELECT -interact NTN_PO _EPTMPL262421 -outputlayer _EPTMPL262422;
EDGE_BOOLEAN -coincident_only -inside _EPTMPL262422 POLY -outputlayer NTN_PO_W;

RULE NT_N.I.1 {
    CAPTION "NT_N interact DNW is not allowed. (Butted is allowed)";
    AND NTN DNW ; // -outputlayer _EPTMPL262424
}

RULE NT_N.I.2 {
    CAPTION "only one OD region allowed to be put in an NT_N region";
    SELECT -enclose NTN OD -gt 1 ; // -outputlayer _EPTMPL262425
}

RULE NT_N.I.3 {
    CAPTION "A P+GATE is not allowed to be put in an NT_N region";
    AND NTN GATE_PP ; // -outputlayer _EPTMPL262426
}

RULE NT_N.I.4 {
    CAPTION "A bent poly region is not allowed to put in an NT_N region";
    EXTE NTN_PO_W -lt 0.18 -abut -eq 90 -intersecting ONLY ; // -outputlayer _EPTMPL262427
    INTE NTN_PO_W -lt 0.18 -abut -eq 90 -intersecting ONLY ; // -outputlayer _EPTMPL262428
    EXTE NTN_PO_W -lt 0.18 -abut -eq 135 -intersecting ONLY ; // -outputlayer _EPTMPL262429
    INTE NTN_PO_W -lt 0.18 -abut -eq 135 -intersecting ONLY ; // -outputlayer _EPTMPL262430
}

RULE NT_N.W.1 {
    CAPTION "For CL018LV 1.5V/2.5V, CL018G 1.8V/3.3V minimum dimension of a NT_N region < 0.74";
    INTE NTN -lt "NT_N_W_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262431
}

RULE NT_N.W.2_LV {
    CAPTION "Minimum Poly gate dimension of a 1.8V blocked NT_N device < 0.5";
    INTE NTN_GATE_W -lt 0.5 -abut -lt 90 -output region ; // -outputlayer _EPTMPL262432
}

RULE NT_N.W.2_3.3V {
    CAPTION "For CL018LV 1.5V/3.3V, CL018LV 1.5V/2.5V, CL018G 1.8V/3.3V, minimum Poly gate dimension of a {2.5V or 3.3V} blocked NT_N device < 1.2";
    EDGE_BOOLEAN -inside NTN_GATE_W OD2 -outputlayer Z;
    INTE Z -lt 1.2 -abut -lt 90 -output region ; // -outputlayer _EPTMPL262434
}

RULE NT_N.S.1 {
    CAPTION "Minimum space between two NT_N regions < 0.86";
    EXTE NTN -lt "NT_N_S_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262435
}

RULE NT_N.E.1 {
    CAPTION "Maximum and Minimum extension from NT_N region beyond an NP OD region 0.26";
    SELECT -interact NTN NPOD -outputlayer A;
    SELECT -interact NPOD NTN -outputlayer B;
    SIZE B -by "NT_N_E_1" -outputlayer C;
    SIZE A -by -NT_N_E_1 -outputlayer D;
    XOR A C ; // -outputlayer _EPTMPL262440
    XOR B D ; // -outputlayer _EPTMPL262441
}

RULE NT_N.C.1 {
    CAPTION "MInimum clearance from NT_N to OD < 0.52";
    EXTE OD NTN -lt "NT_N_C_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262442
    SELECT -cut OD NTN ; // -outputlayer _EPTMPL262443
}

RULE NT_N.C.2 {
    CAPTION "Minimum clearance frome a NT_N region to NWEL edge < 1.66";
    EXTE NTN NWEL -lt 1.66 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262444
    AND NTN NWEL ; // -outputlayer _EPTMPL262445
}

RULE NT_N.PO.1 {
    CAPTION "Minimum overlap of a PO region extended into field oxide(endcap) < 0.35";
    ENC NTN_OD POLY -lt 0.35 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262446
}

RULE OD.W.1_OD.W.2 {
    CAPTION "Min. OD width for MOS and interconnect < 0.22";
    INTE OD -lt 0.22 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262447
}

RULE OD.S.1 {
    CAPTION "Min. OD space < 0.28";
    EXTE OD -lt 0.28 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262448
}

RULE OD.C.1 {
    CAPTION "Min. NWEL olap NPOD tie down < 0.12";
    ENC NPOD NONWR -lt 0.12 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262449
    SELECT -cut NPOD NONWR ; // -outputlayer _EPTMPL262450
}

RULE OD.C.2_OD.C.3 {
    CAPTION "Min. NWEL to NPOD space < 0.43";
    SELECT -inside -not NPOD NWEL -outputlayer A;
