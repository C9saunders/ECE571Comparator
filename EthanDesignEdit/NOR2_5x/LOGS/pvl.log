}

RULE VIA1.E.2 {
    CAPTION "Min. extension of M1 end-of-line region beyond VIA1 region < 0.06";
    ENC VIA1 M1 -lt 0.06 -abut -lt 90 -metric opposite -output positive1 -outputlayer X;
    INTE X -lt 0.26 -abut -eq 90 -intersecting ONLY ; // -outputlayer _EPTMPL262785
}

RULE M2.W.1 {
    CAPTION "Min. M2 width < 0.28";
    INTE M2 -lt 0.28 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262786
}

RULE M2.S.1 {
    CAPTION "Min. M2 space < 0.28";
    EXTE M2 -lt 0.28 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262787
}

RULE M2.S.2 {
    CAPTION "Min. space to wide M2 (>10um) < 0.6";
    SHRINK M2 -right 5 -outputlayer _EPTMPL262788;
    SHRINK _EPTMPL262788 -left 5 -outputlayer _EPTMPL262789;
    SHRINK _EPTMPL262789 -top 5 -outputlayer _EPTMPL262790;
    SHRINK _EPTMPL262790 -bottom 5 -outputlayer M2_S5;
    GROW M2_S5 -right 5 -outputlayer _EPTMPL262792;
    GROW _EPTMPL262792 -left 5 -outputlayer _EPTMPL262793;
    GROW _EPTMPL262793 -top 5 -outputlayer _EPTMPL262794;
    GROW _EPTMPL262794 -bottom 5 -outputlayer M2_G5;
    AND M2_G5 M2 -outputlayer M2_Wide;
    SIZE M2_Wide -by 1 -inside_of M2 -step 0.196 -outputlayer M2_Exp;
    NOT M2_Exp M2_Wide -outputlayer M2_Branch;
    EDGE_BOOLEAN -coincident_only -inside M2_Branch M2 -outputlayer M2_Branch_edge;
    SIZE M2_Exp -by 0.6 -outputlayer _EPTMPL262800;
    AND M2 _EPTMPL262800 -outputlayer M2_Check;
    EDGE_EXPAND M2_Branch_edge -outside_by 0.6 -corner_fill -outputlayer _EPTMPL262802;
    AND M2 _EPTMPL262802 -outputlayer M2_Branch_Check;
    STAMP M2_Wide M2xd -outputlayer M2_WideC;
    STAMP M2_Check M2xd -outputlayer M2_CheckC;
    STAMP M2_Branch M2xd -outputlayer M2_BranchC;
    STAMP M2_Branch_Check M2xd -outputlayer M2_Branch_CheckC;
    EXTE M2_WideC M2_CheckC -lt 0.6 -abut -ltgt 0 89.5 -not_connected -output region ; // -outputlayer _EPTMPL262808
    EXTE M2_BranchC M2_Branch_CheckC -lt 0.6 -abut -ltgt 0 89.5 -not_connected -output region ; // -outputlayer _EPTMPL262809
}

RULE M2.S.2.1.a {
    CAPTION "Min. space betweem wide metal and small piece of metal with parallel run length >= 35 and same connection >=0.6 um";
    SHRINK M2 -right 5 -outputlayer _EPTMPL262810;
    SHRINK _EPTMPL262810 -left 5 -outputlayer _EPTMPL262811;
    SHRINK _EPTMPL262811 -top 5 -outputlayer _EPTMPL262812;
    SHRINK _EPTMPL262812 -bottom 5 -outputlayer M2_S5;
    GROW M2_S5 -right 5 -outputlayer _EPTMPL262814;
    GROW _EPTMPL262814 -left 5 -outputlayer _EPTMPL262815;
    GROW _EPTMPL262815 -top 5 -outputlayer _EPTMPL262816;
    GROW _EPTMPL262816 -bottom 5 -outputlayer M2_G5;
    AND M2_G5 M2 -outputlayer M2_Wide;
    NOT M2 M2_Wide -outputlayer M2_Small;
