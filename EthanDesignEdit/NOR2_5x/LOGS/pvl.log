}

RULE FPAD.R.1 {
    CAPTION "Floating PAD is not allowed . please add protection diode to ground .";
    CAPTION "Floating PAD in the DRC : {Mn INTERACT CB} don't connect OD or POLY";
    SELECT -interact M3 CB -outputlayer A;
    STAMP A M3xd -outputlayer A1;
    ANTENNA A1 NTAPi -gt 0 -outputlayer B1;
    ANTENNA A1 PTAPi -gt 0 -outputlayer B2;
    ANTENNA A1 NSDi -gt 0 -outputlayer B3;
    ANTENNA A1 PSDi -gt 0 -outputlayer B4;
    ANTENNA A1 ILP1i -gt 0 -outputlayer B5;
    OR B1 B2 -outputlayer _EPTMPL264628;
    OR _EPTMPL264628 B3 -outputlayer _EPTMPL264629;
    OR _EPTMPL264629 B4 -outputlayer _EPTMPL264630;
    OR _EPTMPL264630 B5 -outputlayer _EPTMPL264631;
    NOT A _EPTMPL264631 ; // -outputlayer _EPTMPL264632
}
