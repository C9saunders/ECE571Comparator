RULE LUP.1g {
    CAPTION "Any N+ OD injector or an N+ OD injector cluster connected to an I/O pad must be surrounded by a P+ guard-ring.";
    CAPTION "Any P+ OD injector or a P+ OD injector cluster connected to an I/O pad must be surrounded by a N+ guard-ring.";
    SELECT -inside -not POST_DRIVER_NACT PTAP_guard_ring_hole ; // -outputlayer _EPTMPL264183
    SELECT -inside -not POST_DRIVER_PACT NTAP_guard_ring_hole ; // -outputlayer _EPTMPL264184
}

RULE LUP.2g {
    CAPTION "Within 20 um space from the OD injector connected to an I/O pad, a P+ guard-ring is required to surround an NACT or an NACT cluster. And an N+ guard-ring is required to surround a PACT or a PACT cluster.";
    SELECT -interact DNW BESIDE_POST_DRIVER_NMOS_RW -outputlayer _EPTMPL264185;
    SELECT -interact NWEL _EPTMPL264185 -outputlayer _EPTMPL264186;
    SELECT -interact _EPTMPL264186 POST_DRIVER_PMOS_NW -outputlayer _EPTMPL264187;
    SELECT -interact DNW _EPTMPL264187 -outputlayer _EPTMPL264188;
    SELECT -interact BESIDE_POST_DRIVER_NMOS_RW _EPTMPL264188 -outputlayer X;
    EXTE POST_DRIVER_PMOS_NWi BESIDE_POST_DRIVER_NMOS_RWi -lt "LUP_2" -abut -lt 90 -single_point -not_connected -output positive2 -outputlayer Y;
    SELECT -interact -not BESIDE_POST_DRIVER_NMOS_RWi X -outputlayer _EPTMPL264191;
    SELECT -with_edge -not _EPTMPL264191 Y -outputlayer BESIDE_POST_DRIVER_NMOS_waive;
    NOT BESIDE_POST_DRIVER_NACT BESIDE_POST_DRIVER_NMOS_waive -outputlayer _EPTMPL264193;
    SELECT -inside -not _EPTMPL264193 PTAP_guard_ring_hole ; // -outputlayer _EPTMPL264194
    SELECT -inside -not BESIDE_POST_DRIVER_PACT NTAP_guard_ring_hole ; // -outputlayer _EPTMPL264195
}

RULE LUP.3.1g_1.8V {
    CAPTION "For the N/PMOS which connects to an I/O pad, space between the NMOS and the 1.8V PMOS.Except the NMOS is enclosed by a DNW and the NW of the checked PMOS is not interacted to the DNW. >= 3 um";
    EXTE POST_DRIVER_PMOS_NW_LV POST_DRIVER_NMOS_PW -lt "LUP_3_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264196
    EXTE POST_DRIVER_PMOS_NW_LV POST_DRIVER_NMOS_RW -lt "LUP_3_1" -abut -lt 90 -single_point -output region -connected ; // -outputlayer _EPTMPL264197
    EXTE POST_DRIVER_PMOS_NWi_LV POST_DRIVER_NMOS_RWi -lt "LUP_3_1" -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL264198
}

RULE LUP.3.3g_3.3V {
    CAPTION "For the N/PMOS which connects to an I/O pad directly, space between the 3.3V PMOS and NMOS, Except the NMOS is enclosed by a DNW and the NW of the checked PMOS is not interacted to the DNW. >= 12 um";
    EXTE POST_DRIVER_NMOS_PW POST_DRIVER_PMOS_NW_HV -lt "LUP_3_3" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264199
    EXTE POST_DRIVER_NMOS_RW POST_DRIVER_PMOS_NW_HV -lt "LUP_3_3" -abut -lt 90 -single_point -output region -connected ; // -outputlayer _EPTMPL264200
    EXTE POST_DRIVER_NMOS_RWi POST_DRIVER_PMOS_NWi_HV -lt "LUP_3_3" -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL264201
}

RULE LUP.4g {
    CAPTION "Width of the N+ guard-ring, P+ guard-ring, N+ STRAP and P+ STRAP for the Active connected to an I/O pad, and also MOS within 20um space from the MOS connected to an I/O pad. >= 0.42 um";
    OR POST_DRIVER_NACT BESIDE_POST_DRIVER_NMOS -outputlayer _EPTMPL264202;
    SELECT -enclose PTAP_guard_ring_hole _EPTMPL264202 -outputlayer PTAP_guard_ring_holex;
    OR POST_DRIVER_PACT BESIDE_POST_DRIVER_PMOS -outputlayer _EPTMPL264204;
    SELECT -enclose NTAP_guard_ring_hole _EPTMPL264204 -outputlayer NTAP_guard_ring_holex;
    SELECT -touch PTAPi PTAP_guard_ring_holex -outputlayer _EPTMPL264206;
    WITH_WIDTH _EPTMPL264206 -ge "LUP_4" -outputlayer PTAP_guard_ring_wide;
    SELECT -touch NTAPi NTAP_guard_ring_holex -outputlayer _EPTMPL264208;
    WITH_WIDTH _EPTMPL264208 -ge "LUP_4" -outputlayer NTAP_guard_ring_wide;
    HOLES PTAP_guard_ring_wide -inner -outputlayer _EPTMPL264210;
    SELECT -inside _EPTMPL264210 PWELi -outputlayer PTAP_guard_ring_wide_hole;
    HOLES NTAP_guard_ring_wide -inner -outputlayer _EPTMPL264212;
    SELECT -inside _EPTMPL264212 NWELi -outputlayer NTAP_guard_ring_wide_hole;
    SELECT -inside -not PTAP_guard_ring_holex PTAP_guard_ring_wide_hole -outputlayer PTAP_guard_ring_hole_check;
    SELECT -inside -not NTAP_guard_ring_holex NTAP_guard_ring_wide_hole -outputlayer NTAP_guard_ring_hole_check;
    EDGE_BOOLEAN -coincident_only -outside PTAPi PTAP_guard_ring_hole_check -outputlayer PTAP_guard_ring_check;
    EDGE_BOOLEAN -coincident_only -outside NTAPi NTAP_guard_ring_hole_check -outputlayer NTAP_guard_ring_check;
    INTE PTAP_guard_ring_check PTAPi -lt "LUP_4" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264218
    INTE NTAP_guard_ring_check NTAPi -lt "LUP_4" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264219
}

RULE LUP.5.1g_1.8V {
    CAPTION "Minimum space >= 3 um";
    CAPTION "1. between N+ OD injector and the the 1.8V PMOS in the internal circuit";
    CAPTION "2. between 1.8V P+ OD injector and the NMOS in the internal circuit";
    EXTE POST_DRIVER_PINJ_NW_LV BESIDE_POST_DRIVER_NMOS_PW -lt "LUP_5_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264220
    EXTE POST_DRIVER_PINJ_NW_LV BESIDE_POST_DRIVER_NMOS_RW -lt "LUP_5_1" -abut -lt 90 -single_point -output region -connected ; // -outputlayer _EPTMPL264221
    EXTE POST_DRIVER_PINJ_NWi_LV BESIDE_POST_DRIVER_NMOS_RWi -lt "LUP_5_1" -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL264222
    EXTE POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_LV -lt "LUP_5_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264223
    EXTE POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_LV -lt "LUP_5_1" -abut -lt 90 -single_point -output region -connected ; // -outputlayer _EPTMPL264224
    EXTE POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_LV -lt "LUP_5_1" -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL264225
}

RULE LUP.5.3g_3.3V {
    CAPTION "Minimum space >= 12 um";
    CAPTION "1. between N+ OD injector and the the 3.3V PMOS in the internal circuit";
    CAPTION "2. between 3.3V P+ OD injector and the NMOS in the internal circuit";
    EXTE POST_DRIVER_PINJ_NW_HV BESIDE_POST_DRIVER_NMOS_PW -lt "LUP_5_3" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264226
    EXTE POST_DRIVER_PINJ_NW_HV BESIDE_POST_DRIVER_NMOS_RW -lt "LUP_5_3" -abut -lt 90 -single_point -output region -connected ; // -outputlayer _EPTMPL264227
    EXTE POST_DRIVER_PINJ_NWi_HV BESIDE_POST_DRIVER_NMOS_RWi -lt "LUP_5_3" -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL264228
    EXTE POST_DRIVER_NINJ_PW BESIDE_POST_DRIVER_PMOS_NW_HV -lt "LUP_5_3" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264229
    EXTE POST_DRIVER_NINJ_RW BESIDE_POST_DRIVER_PMOS_NW_HV -lt "LUP_5_3" -abut -lt 90 -single_point -output region -connected ; // -outputlayer _EPTMPL264230
    EXTE POST_DRIVER_NINJ_RWi BESIDE_POST_DRIVER_PMOS_NWi_HV -lt "LUP_5_3" -abut -lt 90 -single_point -output region -not_connected ; // -outputlayer _EPTMPL264231
}
SELECT -outside -not PSDc COi -outputlayer _EPTMPL264232;
OR COi _EPTMPL264232 -outputlayer CO_PACT;
SELECT -interact NTAPi CO_PACT -outputlayer NPUi;
SELECT -inside NPUi SRM -outputlayer NPUi_SRAM;
SIZE NPUi -by "LUP_6" -inside_of NWELi -step "NW_S_1*0.7" -truncate "NW_S_1*0.7" -outputlayer NSTP_OS;
SIZE NPUi_SRAM -by "LUP_6_SRAM" -inside_of NWELi -step "NW_S_1*0.7" -truncate "NW_S_1*0.7" -outputlayer NSTP_OS_SRAM;
SELECT -interact PACTi COi -outputlayer _EPTMPL264238;
SELECT -interact _EPTMPL264238 POLYi -outputlayer _EPTMPL264239;
NOT _EPTMPL264239 POLYi -outputlayer PACT_CHECK;
SELECT -inside -not PACT_CHECK SRM -outputlayer PACT_CHECK_NON_SRAM;
SELECT -inside PACT_CHECK SRM -outputlayer PACT_CHECK_SRAM;
SELECT -outside -not NSDc COi -outputlayer _EPTMPL264243;
OR COi _EPTMPL264243 -outputlayer CO_NACT;
SELECT -interact PTAPi CO_NACT -outputlayer PPUi;
SELECT -inside PPUi SRM -outputlayer PPUi_SRAM;
SIZE PPUi -by "LUP_6" -inside_of PWELi -step "NW_S_1*0.7" -truncate "NW_S_1*0.7" -outputlayer PSTP_OS;
SIZE PPUi_SRAM -by "LUP_6_SRAM" -inside_of PWELi -step "NW_S_1*0.7" -truncate "NW_S_1*0.7" -outputlayer PSTP_OS_SRAM;
SELECT -interact NACTi COi -outputlayer _EPTMPL264249;
SELECT -interact _EPTMPL264249 POLYi -outputlayer _EPTMPL264250;
NOT _EPTMPL264250 POLYi -outputlayer NACT_CHECK;
SELECT -inside -not NACT_CHECK SRM -outputlayer NACT_CHECK_NON_SRAM;
SELECT -inside NACT_CHECK SRM -outputlayer NACT_CHECK_SRAM;

RULE LUP.6g {
    CAPTION "Any point inside NMOS source/drain space to the nearest PW STRAP in the same PW <= 30 um";
    CAPTION "Any point inside PMOS source/drain space to the nearest NW STRAP in the same NW <= 30 um";
    CAPTION "In SRAM bit cell region, the rule is relaxed to 40 um";
    NOT PACT_CHECK_NON_SRAM NSTP_OS ; // -outputlayer _EPTMPL264254
    OR NSTP_OS NSTP_OS_SRAM -outputlayer _EPTMPL264255;
    NOT PACT_CHECK_SRAM _EPTMPL264255 ; // -outputlayer _EPTMPL264256
    NOT NACT_CHECK_NON_SRAM PSTP_OS ; // -outputlayer _EPTMPL264257
    OR PSTP_OS PSTP_OS_SRAM -outputlayer _EPTMPL264258;
    NOT NACT_CHECK_SRAM _EPTMPL264258 ; // -outputlayer _EPTMPL264259
}

RULE LUP.10g__LUP.13g {
    CAPTION "For Area I/O, within 75 um from OD injector (covered by LUPWDMY_2 or turn on ALL_AREA_IO switch)";
    CAPTION "Any point inside NMOS source/drain space to the nearest PW STRAP in the same PW <= 15 um";
    CAPTION "Any point inside PMOS source/drain space to the nearest NW STRAP in the same NW <= 15 um";
    SELECT -outside -not POST_DRIVER_ACT LUPWDMY_2 -outputlayer TRIGGER_SOURCE;
    NOT NACT_CHECK TRIGGER_SOURCE -outputlayer _EPTMPL264261;
    SELECT -inside -not _EPTMPL264261 PTAP_guard_ring_hole -outputlayer CORE_LOGIC_NACT;
    NOT PACT_CHECK TRIGGER_SOURCE -outputlayer _EPTMPL264263;
    SELECT -inside -not _EPTMPL264263 NTAP_guard_ring_hole -outputlayer CORE_LOGIC_PACT;
    SIZE TRIGGER_SOURCE -by "LUP_10" -bevel 4 -outputlayer _EPTMPL264265;
    SELECT -outside -not CORE_LOGIC_NACT _EPTMPL264265 -outputlayer NACT_LUP;
    SIZE TRIGGER_SOURCE -by "LUP_10" -bevel 4 -outputlayer _EPTMPL264267;
    SELECT -outside -not CORE_LOGIC_PACT _EPTMPL264267 -outputlayer PACT_LUP;
    SIZE PPUi -by "LUP_13" -inside_of PWELi -step "NW_S_1*0.7" -truncate "NW_S_1*0.7" -outputlayer PSTP_OS;
    NOT NACT_LUP PSTP_OS ; // -outputlayer _EPTMPL264270
    SIZE NPUi -by "LUP_13" -inside_of NWELi -step "NW_S_1*0.7" -truncate "NW_S_1*0.7" -outputlayer NSTP_OS;
    NOT PACT_LUP NSTP_OS ; // -outputlayer _EPTMPL264272
}

RULE LUP.14g {
    CAPTION "For Area I/O, width of picup ring and guard rings for the OD injector >= 0.42";
    SELECT -outside -not POST_DRIVER_NACT LUPWDMY_2 -outputlayer AREA_IO_NACT;
    SELECT -outside -not POST_DRIVER_PACT LUPWDMY_2 -outputlayer AREA_IO_PACT;
    SELECT -inside -not AREA_IO_NACT PTAP_guard_ring_hole ; // -outputlayer _EPTMPL264275
    SELECT -inside -not AREA_IO_PACT NTAP_guard_ring_hole ; // -outputlayer _EPTMPL264276
    HOLES PTAPi -inner -outputlayer _EPTMPL264277;
    SELECT -interact _EPTMPL264277 AREA_IO_PACT -outputlayer _EPTMPL264278;
    SELECT -interact -not _EPTMPL264278 NACT -outputlayer PTAP_guard_ring_2nd;
    HOLES NTAPi -inner -outputlayer _EPTMPL264280;
    SELECT -interact _EPTMPL264280 AREA_IO_NACT -outputlayer _EPTMPL264281;
    SELECT -interact -not _EPTMPL264281 PACT -outputlayer NTAP_guard_ring_2nd;
    SELECT -inside -not AREA_IO_NACT NTAP_guard_ring_2nd ; // -outputlayer _EPTMPL264283
    SELECT -inside -not AREA_IO_PACT PTAP_guard_ring_2nd ; // -outputlayer _EPTMPL264284
    SELECT -interact PTAP_guard_ring_hole AREA_IO_NACT -outputlayer _EPTMPL264285;
    EDGE_BOOLEAN -coincident_only -outside PTAPi _EPTMPL264285 -outputlayer PTAP_guard_ring_hole_edge;
    SELECT -interact NTAP_guard_ring_hole AREA_IO_PACT -outputlayer _EPTMPL264287;
    EDGE_BOOLEAN -coincident_only -outside NTAPi _EPTMPL264287 -outputlayer NTAP_guard_ring_hole_edge;
    INTE PTAP_guard_ring_hole_edge PTAPi -lt "LUP_14" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264289
    INTE NTAP_guard_ring_hole_edge NTAPi -lt "LUP_14" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264290
    EDGE_BOOLEAN -coincident_only -outside PTAPi PTAP_guard_ring_2nd -outputlayer PTAP_guard_ring_2nd_edge;
    EDGE_BOOLEAN -coincident_only -outside NTAPi NTAP_guard_ring_2nd -outputlayer NTAP_guard_ring_2nd_edge;
    INTE PTAP_guard_ring_2nd_edge PTAPi -lt "LUP_14" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264293
    INTE NTAP_guard_ring_2nd_edge NTAPi -lt "LUP_14" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264294
}

RULE LOGO.S.1 {
    CAPTION "Min. LOGO space to NW, OD, PO, or Metals >= 3um";
    SIZE LOGO -by 3 -outputlayer _EPTMPL264295;
    NOT _EPTMPL264295 LOGO -outputlayer LOGO_EXT;
    AND LOGO_EXT NWELi ; // -outputlayer _EPTMPL264297
    AND LOGO_EXT ALL_OD ; // -outputlayer _EPTMPL264298
    AND LOGO_EXT ALL_PO ; // -outputlayer _EPTMPL264299
    OR M1i M1DMY -outputlayer _EPTMPL264300;
    AND LOGO_EXT _EPTMPL264300 ; // -outputlayer _EPTMPL264301
    OR M2i M2DMY -outputlayer _EPTMPL264302;
    AND LOGO_EXT _EPTMPL264302 ; // -outputlayer _EPTMPL264303
    OR M3i M3DMY -outputlayer _EPTMPL264304;
    AND LOGO_EXT _EPTMPL264304 ; // -outputlayer _EPTMPL264305
    OR MD MDDMY -outputlayer _EPTMPL264306;
    AND LOGO_EXT _EPTMPL264306 ; // -outputlayer _EPTMPL264307
}

RULE LOGO.O.1 {
    CAPTION "LOGO overlap of CB, CBD, FW, PM, UBM, DOD, DPO, PPI or DMx is not allowed.";
    AND LOGO CBi ; // -outputlayer _EPTMPL264308
    AND LOGO CBDi ; // -outputlayer _EPTMPL264309
    AND LOGO PPIi ; // -outputlayer _EPTMPL264310
    AND LOGO FWi ; // -outputlayer _EPTMPL264311
    AND LOGO PLMIDEi ; // -outputlayer _EPTMPL264312
    AND LOGO UBMi ; // -outputlayer _EPTMPL264313
    AND LOGO DOD ; // -outputlayer _EPTMPL264314
    AND LOGO DPO ; // -outputlayer _EPTMPL264315
    AND LOGO M1DMY ; // -outputlayer _EPTMPL264316
    AND LOGO M2DMY ; // -outputlayer _EPTMPL264317
    AND LOGO M3DMY ; // -outputlayer _EPTMPL264318
    AND LOGO MDDMY ; // -outputlayer _EPTMPL264319
}

RULE LOGO.R.1 {
    CAPTION "A circuit in LOGO is not allowed.";
    AND LOGO ALL_GATE ; // -outputlayer _EPTMPL264320
    AND LOGO PORES ; // -outputlayer _EPTMPL264321
    AND LOGO ODRES ; // -outputlayer _EPTMPL264322
    AND LOGO RNWEL ; // -outputlayer _EPTMPL264323
    AND LOGO BJTDUMMY ; // -outputlayer _EPTMPL264324
    AND LOGO DIODUMMY ; // -outputlayer _EPTMPL264325
    AND LOGO VARDMY ; // -outputlayer _EPTMPL264326
    AND LOGO CTM2i ; // -outputlayer _EPTMPL264327
}

RULE PO.W.1_HRI {
    CAPTION "Min. width of PO region for HRI poly resistor >= 1.0um";
    SELECT -interact HREP RLPPDMY -outputlayer HREPC_CHECK;
    INTE HREPC_CHECK -lt 1 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264329
}

RULE _PO.R.1A.MM {
    CAPTION "90 degree L shape and U shape bent gates are not allowed";
    EDGE_BOOLEAN -outside GATE_W VARDMY -outputlayer NORM_GATE_W;
    EXTE NORM_GATE_W -lt 0.18 -abut -eq 90 -intersecting ONLY ; // -outputlayer _EPTMPL264331
    INTE NORM_GATE_W -lt 0.18 -abut -eq 90 -intersecting ONLY ; // -outputlayer _EPTMPL264332
}

RULE _PP.E.6.MM {
    CAPTION "Min. extension of a PP region beyond a PO as resistor >= 0.18 um";
    ENC PORES PP -lt "PP_E_6_2" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264333
    AND RPO POLY -outputlayer _EPTMPL264334;
    NOT _EPTMPL264334 IMP -outputlayer _EPTMPL264335;
    NOT _EPTMPL264335 HRI ; // -outputlayer _EPTMPL264336
}

RULE RPO.O.1_HRI {
    CAPTION "Min. and Max. overlap of a PP region to RPO region for HRI == 0.3um";
    SELECT -interact POLY_ISO HRI -outputlayer X;
    EDGE_BOOLEAN -inside RPO X -outputlayer Y;
    INTE PP Y -lt 0.3 -abut -lt 90 ; // -outputlayer _EPTMPL264339
    EDGE_BOOLEAN -outside Y PP ; // -outputlayer _EPTMPL264340
    EDGE_EXPAND Y -inside_by 0.3 -outputlayer Z;
    AND PP POLY -outputlayer PPPO;
    AND PPPO PORES -outputlayer A;
    SELECT -interact A HRI -outputlayer B;
    NOT B Z ; // -outputlayer _EPTMPL264345
}
NOT M3xd INDDMY -outputlayer M3T_NIND;
SIZE INDDMY -by -7 -outputlayer INDDMYI;
AND INDDMY M1 -outputlayer INDM;
EDGE_BOOLEAN -coincident_only -inside INDM INDDMY -outputlayer INDME;
SELECT -with_edge INDDMY INDME -lt 2 -outputlayer INDDMYA;
SELECT -enclose INDDMYA M2 -outputlayer INDDMY3;
NOT INDDMY INDDMY3 -outputlayer INDDMY2;
SELECT -inside PWEL DNW -outputlayer RW;

RULE DNW.W.1 {
    CAPTION "Min. width of a DNW region >= 3um";
    INTE DNW -lt 3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264354
}

RULE DNW.S.1 {
    CAPTION "Min. space between two DNW regions >= 5um";
    EXTE DNW -lt 5 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264355
}

RULE DNW.O.1 {
    CAPTION "Min. overlap from a NW edge to a DNW region >= 2.0um";
    INTE DNW NWEL -lt 2 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264356
}
CONNECT NWEL DNW;

RULE DNW.C.1 {
    CAPTION "Min. clearance from DNW to NW >= 3.5um";
    EXTE NWEL DNW -lt 3.5 -abut -lt 90 -single_point -output region -not_connected -measure all ; // -outputlayer _EPTMPL264358
}

RULE DNW.C.4 {
    CAPTION "Min. clearance from DNW to N+OD outside NW >= 3.0um";
    NOT PWEL DNW -outputlayer A;
    SELECT -interact NPOD A -outputlayer B;
    EXTE B DNW -lt 3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264361
    SELECT -cut B DNW ; // -outputlayer _EPTMPL264362
}

RULE DNW.E.2 {
    CAPTION "Min. extension of DNW beyond N+OD outside NW >= 1.5um";
    AND PWEL DNW -outputlayer A;
    SELECT -interact NPOD A -outputlayer B;
    ENC B DNW -lt 1.5 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264365
    SELECT -cut B DNW ; // -outputlayer _EPTMPL264366
}

RULE DNW.R.4 {
    CAPTION "It is not allowed to use DNW as a resistor";
    AND DNW RWDMY ; // -outputlayer _EPTMPL264367
}

RULE DNW.R.5 {
    CAPTION "It is not allowed to use {NW interact DNW} as a resistor";
    SELECT -interact RNWEL DNW ; // -outputlayer _EPTMPL264368
    SELECT -interact NWRES DNW ; // -outputlayer _EPTMPL264369
}

RULE VTM_N.W.1 {
    CAPTION "Min. dimension of a VTM_N region >= 0.74um";
    INTE VTMN -lt 0.74 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264370
}

RULE VTM_N.W.2 {
    CAPTION "Min. PO gate dimension of a 1.8V medium Vt NMOS >= 0.3um";
    EDGE_BOOLEAN -inside GATE_W VTMN -outputlayer Z;
    INTE Z -lt 0.3 -abut -lt 90 -output region ; // -outputlayer _EPTMPL264372
}

RULE VTM_N.W.3 {
    CAPTION "Min. PO gate dimension of a 3.3V medium Vt NMOS >= 0.6um";
    EDGE_BOOLEAN -inside HV_NGATE_W VTMN -outputlayer Z;
    INTE Z -lt 0.6 -abut -lt 90 -output region ; // -outputlayer _EPTMPL264374
}

RULE VTM_N.S.1 {
    CAPTION "Min. space between two VTM_N regions >= 0.44um";
    EXTE VTMN -lt 0.44 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264375
}

RULE VTM_N.E.1 {
    CAPTION "Min. extension from a VTM_N region beyond an N+OD region >= 0.26um";
    ENC NACT VTMN -lt 0.26 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264376
    SELECT -cut NACT VTMN ; // -outputlayer _EPTMPL264377
}

RULE VTM_N.C.1 {
    CAPTION "Min. clearance from a VTM_N region to an N+OD region >= 0.7um";
    EXTE NACT VTMN -lt 0.7 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264378
}

RULE VTM_N.C.2 {
    CAPTION "Min. clearance from a VTM_N region to an NW edge >= 0.43um";
    EXTE VTMN NWEL -lt 0.43 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264379
    AND VTMN NWEL ; // -outputlayer _EPTMPL264380
}

RULE VTM_N.R.2 {
    CAPTION "VTM_N interact NT_N is not allowed (butted is allowed)";
    AND VTMN NTN ; // -outputlayer _EPTMPL264381
}

RULE VTM_N.R.3 {
    CAPTION "A P+ Gate is not allowed in VTM_N region";
    AND VTMN GATE_PP ; // -outputlayer _EPTMPL264382
}

RULE VTM_N.R.4 {
    CAPTION "A bent PO region is not allowed in VTM_N region";
    AND POLY VTMN -outputlayer VTMN_PO;
    VERTEX VTMN_PO -ne 4 ; // -outputlayer _EPTMPL264384
}

RULE VTM_N.R.5 {
    CAPTION "Min. clearance from an OD region in VTM_N region to a PO on field oxide >= 0.26um";
    AND VTMN OD -outputlayer VTMN_OD;
    EXTE VTMN_OD POLY_ISO -lt 0.26 -abut -ltgt 0 90 -single_point -output region ; // -outputlayer _EPTMPL264386
}

RULE VTM_P.W.1 {
    CAPTION "Min. dimension of a VTM_P region >= 0.74um";
    INTE VTMP -lt 0.74 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264387
}

RULE VTM_P.W.2 {
    CAPTION "Min. PO gate dimension of a 1.8V medium Vt PMOS >= 0.25um";
    EDGE_BOOLEAN -inside GATE_W VTMP -outputlayer Z;
    INTE Z -lt 0.25 -abut -lt 90 -output region ; // -outputlayer _EPTMPL264389
}

RULE VTM_P.S.1 {
    CAPTION "Min. space between two VTM_P regions >= 0.44um";
    EXTE VTMP -lt 0.44 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264390
}

RULE VTM_P.E.1 {
    CAPTION "Min. extension from a VTM_P region beyond a P+OD region >= 0.26um";
    ENC PACT VTMP -lt 0.26 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264391
    SELECT -cut PACT VTMP ; // -outputlayer _EPTMPL264392
}

RULE VTM_P.C.1 {
    CAPTION "Min. clearance from a VTM_P region to a P+OD region >= 0.7um";
    EXTE PACT VTMP -lt 0.7 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264393
}

RULE VTM_P.C.2 {
    CAPTION "Min. clearance from a VTM_P region to a PW edge >= 0.43um";
    ENC VTMP NWEL -lt 0.43 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264394
    NOT VTMP NWEL ; // -outputlayer _EPTMPL264395
}

RULE VTM_P.R.2 {
    CAPTION "VTM_P interact NT_N is not allow";
    SELECT -interact VTMP NTN ; // -outputlayer _EPTMPL264396
}

RULE VTM_P.R.3 {
    CAPTION "VTM_P interact OD2 is not allowed.";
    SELECT -interact VTMP OD2 ; // -outputlayer _EPTMPL264397
}

RULE VTM_P.R.4 {
    CAPTION "A N+ Gate is not allowed in VTM_P region";
    AND VTMP GATE_NP ; // -outputlayer _EPTMPL264398
}

RULE VTM_P.R.5 {
    CAPTION "A bent PO region is not allowed in VTM_P region";
    AND POLY VTMP -outputlayer VTMP_PO;
