AND HEGT NP -outputlayer HEGN;
AND HEGT PP -outputlayer HEGP;
SELECT -interact PACTi POLYi -outputlayer _EPTMPL263514;
SELECT -interact _EPTMPL263514 COi -outputlayer PMOSi;
SELECT -interact NACTi POLYi -outputlayer _EPTMPL263516;
SELECT -interact _EPTMPL263516 COi -outputlayer NMOSi;
SELECT -interact NSDk NMOSi -outputlayer _EPTMPL263518;
SELECT -interact _EPTMPL263518 OD2 -outputlayer NSDk_HVMOS;
SELECT -interact NSDk NMOSi -outputlayer _EPTMPL263520;
SELECT -interact -not _EPTMPL263520 OD2 -outputlayer NSDk_LVMOS;
SELECT -interact PSDk PMOSi -outputlayer _EPTMPL263522;
SELECT -interact _EPTMPL263522 OD2 -outputlayer PSDk_HVMOS;
SELECT -interact PSDk PMOSi -outputlayer _EPTMPL263524;
SELECT -interact -not _EPTMPL263524 OD2 -outputlayer PSDk_LVMOS;
SELECT -interact NSDk_HVMOS SDI -outputlayer NSDk_HVMOS_SDI;
SELECT -interact NSDk_LVMOS SDI -outputlayer NSDk_LVMOS_SDI;
SELECT -interact PSDk_HVMOS SDI -outputlayer PSDk_HVMOS_SDI;
SELECT -interact PSDk_LVMOS SDI -outputlayer PSDk_LVMOS_SDI;
STAMP HVGT ILP1k -outputlayer HV_GATEk;
STAMP LVGT ILP1k -outputlayer LV_GATEk;

RULE ESD.1g {
    CAPTION "Use thin oxide transistor for thin oxide power clamp and thin oxide I/O buffers,";
    CAPTION "Use thick oxide transistor for the thick oxide Power Clamp and thick oxide I/O buffers.";
    CAPTION "DRC only flag ((MOS INTERACT OD2) INTERACT SDI) connected to (MOS NOT INTERACT OD2).";
    CAPTION "DRC will exclude D/S/G connected to PWSTRAP.";
    ANTENNA NSDk_HVMOS_SDI NSDk_LVMOS PSDk_LVMOS LV_GATEk PTAPk -gt 0 -expr "  !!AREA(NSDk_HVMOS_SDI)*!AREA(PTAPk)*(!!AREA(NSDk_LVMOS)+!!AREA(PSDk_LVMOS)+!!AREA(LV_GATEk))  " -rdb ESD.1g.hv_n.rep NSDk_HVMOS_SDI NSDk_LVMOS PSDk_LVMOS LV_GATEk ; // -outputlayer _EPTMPL263532
    ANTENNA PSDk_HVMOS_SDI NSDk_LVMOS PSDk_LVMOS LV_GATEk PTAPk -gt 0 -expr "  !!AREA(PSDk_HVMOS_SDI)*!AREA(PTAPk)*(!!AREA(NSDk_LVMOS)+!!AREA(PSDk_LVMOS)+!!AREA(LV_GATEk))  " -rdb ESD.1g.hv_p.rep PSDk_HVMOS_SDI NSDk_LVMOS PSDk_LVMOS LV_GATEk ; // -outputlayer _EPTMPL263533
}

RULE ESD.7g {
    CAPTION "For same type OD of the I/O buffer and Power Clamp should be surrounded by a guard-ring.";
    CAPTION "All other type ODs should be placed outside this guard-ring.";
    SELECT -inside -not EPMOS NTAP_guard_ring_hole ; // -outputlayer _EPTMPL263534
    SELECT -inside -not ENMOS PTAP_guard_ring_hole ; // -outputlayer _EPTMPL263535
}

RULE ESD.9g {
    CAPTION "The OD area of the edge side of I/O buffer and Power Clamp should be Source or Bulk rather than Drain";
    CAPTION "to avoid an unwanted parasitic bipolar effect or an abnormal discharge path in ESD zapping.";
    CAPTION "DRC only flag (((OD INTERACT SDI) NOT PO) INTERACT one Gate) does not connect to STRAP.";
    SELECT -interact NSDu EGTE -eq 1 -outputlayer EDGE_NSD;
    ANTENNA EDGE_NSD PTAPu -gt 0 -expr "  !!AREA(EDGE_NSD)*!AREA(PTAPu)  " ; // -outputlayer _EPTMPL263537
    SELECT -interact PSDu EGTE -eq 1 -outputlayer EDGE_PSD;
    ANTENNA EDGE_PSD NTAPu -gt 0 -expr "  !!AREA(EDGE_PSD)*!AREA(NTAPu)  " ; // -outputlayer _EPTMPL263539
}
ANTENNA CBk NTAPk -gt 0 -outputlayer VDD_CBk;
ANTENNA CBk PTAPk -gt 0 -outputlayer VSS_CBk;
ANTENNA UBMnk NTAPk -gt 0 -outputlayer VDD_UBMnk;
ANTENNA UBMnk PTAPk -gt 0 -outputlayer VSS_UBMnk;
ANTENNA UBMdk NTAPk -gt 0 -outputlayer VDD_UBMdk;
ANTENNA UBMdk PTAPk -gt 0 -outputlayer VSS_UBMdk;
SELECT -interact CBk VDD_VSS_DUMMY -outputlayer CBk_DUMMY;
SELECT -interact UBMnk VDD_VSS_DUMMY -outputlayer UBMnk_DUMMY;
SELECT -interact UBMdk VDD_VSS_DUMMY -outputlayer UBMdk_DUMMY;
NOT CBk VDD_CBk -outputlayer _EPTMPL263549;
NOT _EPTMPL263549 VSS_CBk -outputlayer _EPTMPL263550;
NOT _EPTMPL263550 CBk_DUMMY -outputlayer IO_CBk;
NOT UBMnk VDD_UBMnk -outputlayer _EPTMPL263552;
NOT _EPTMPL263552 VSS_UBMnk -outputlayer _EPTMPL263553;
NOT _EPTMPL263553 UBMnk_DUMMY -outputlayer IO_UBMnk;
NOT UBMdk VDD_UBMdk -outputlayer _EPTMPL263555;
NOT _EPTMPL263555 VSS_UBMdk -outputlayer _EPTMPL263556;
NOT _EPTMPL263556 UBMdk_DUMMY -outputlayer IO_UBMdk;
ANTENNA PSDk IO_CBk IO_UBMnk IO_UBMdk -gt 0 -expr "  !!AREA(IO_CBk)+AREA(IO_UBMnk)+!!AREA(IO_UBMdk)  " -outputlayer PSDk_CB;
ANTENNA NSDk IO_CBk IO_UBMnk IO_UBMdk -gt 0 -expr "  !!AREA(IO_CBk)+AREA(IO_UBMnk)+!!AREA(IO_UBMdk)  " -outputlayer NSDk_CB;
COPY NWEL -outputlayer NWELc;
CONNECT NWELc;
COPY PWEL -outputlayer PWELc;
CONNECT PWELc;

RULE ESD.10g {
    CAPTION "Except the ESD device, either of the following two condition must be followed.";
    CAPTION "1. The space of two same type ODs >= 2.4 um.";
    CAPTION "2. Two same type ODs should be separated by different type OD.";
    CAPTION "The same type ODs are N+OD and N+OD in the same PW, or P+OD and P+OD in the same NW, which connect to two different Pad.";
    SELECT -interact PACT PSDk_CB -outputlayer _EPTMPL263564;
    NOT _EPTMPL263564 EPMOS -outputlayer PACT_CHECK;
    SELECT -interact PACT_CHECK PSDk_CB -eq 1 -by_net -outputlayer _EPTMPL263566;
    STAMP _EPTMPL263566 PSDk_CB -outputlayer PACT_CHECK_CB;
    EXTE PACT_CHECK_CB -lt "ESD_10g" -abut -lt 90 -single_point -output region -not_connected -outputlayer P1;
    SELECT -interact PACT_CHECK P1 -outputlayer _EPTMPL263569;
    STAMP _EPTMPL263569 NWELc -outputlayer PACT_CHECK_NW;
    EXTE PACT_CHECK_NW -lt "ESD_10g" -abut -lt 90 -single_point -output region -connected -outputlayer P2;
    AND P1 P2 -outputlayer ESD_P3;
    NOT ESD_P3 NTAPi -outputlayer _EPTMPL263573;
    SELECT -interact _EPTMPL263573 PACT_CHECK_CB -gt 1 -by_net ; // -outputlayer _EPTMPL263574
    SELECT -interact PACT_CHECK PSDk_CB -gt 1 -by_net ; // -outputlayer _EPTMPL263575
    SELECT -interact NACT NSDk_CB -outputlayer _EPTMPL263576;
    NOT _EPTMPL263576 ENMOS -outputlayer NACT_CHECK;
    SELECT -interact NACT_CHECK NSDk_CB -eq 1 -by_net -outputlayer _EPTMPL263578;
    STAMP _EPTMPL263578 NSDk_CB -outputlayer NACT_CHECK_CB;
    EXTE NACT_CHECK_CB -lt "ESD_10g" -abut -lt 90 -single_point -output region -not_connected -outputlayer N1;
    SELECT -interact NACT_CHECK N1 -outputlayer _EPTMPL263581;
    STAMP _EPTMPL263581 PWELc -outputlayer NACT_CHECK_PW;
    EXTE NACT_CHECK_PW -lt "ESD_10g" -abut -lt 90 -single_point -output region -connected -outputlayer N2;
    AND N1 N2 -outputlayer ESD_N3;
    NOT ESD_N3 PTAPi -outputlayer _EPTMPL263585;
    SELECT -interact _EPTMPL263585 NACT_CHECK_CB -gt 1 -by_net ; // -outputlayer _EPTMPL263586
    SELECT -interact NACT_CHECK NSDk_CB -gt 1 -by_net ; // -outputlayer _EPTMPL263587
}

RULE ESD.3g {
    CAPTION "Total finger width for 5.0V, 3.3V, 2.5V, 1.8V and 1.5V N/PMOS I/O buffer in same connection of drain >= 360";
    ANTENNA ESD_PMOS_GATE_W_EXPc -ge "ESD_3g" -expr "  AREA(ESD_PMOS_GATE_W_EXPc)/GRID  " -outputlayer A;
    SELECT -interact -not EPMOS A ; // -outputlayer _EPTMPL263589
    ANTENNA ESD_NMOS_GATE_W_EXPc -ge "ESD_3g" -expr "  AREA(ESD_NMOS_GATE_W_EXPc)/GRID  " -outputlayer B;
    SELECT -interact -not ENMOS PCL_ENMOS -outputlayer _EPTMPL263591;
    SELECT -interact -not _EPTMPL263591 B ; // -outputlayer _EPTMPL263592
}

RULE ESD.5g {
    CAPTION "Total finger width of 1.8V/1.5V NMOS based fully silicided type active Power Clamp in same connection";
    CAPTION "of drain. 1.8V/1.5V NMOS BigFET Lg only needs to follow process rules >= 2000.";
    ANTENNA ESD_PCL_GATE_W_EXPc -lt "ESD_5g" -expr "  AREA(ESD_PCL_GATE_W_EXPc)/GRID  " -rdb ESD.5g.rep ESD_PCL_GATE_W_EXPc ; // -outputlayer _EPTMPL263593
}

RULE ESD.5.1g {
    CAPTION "Total finger width for 3.3V/2.5V NMOS based fully silicided active type Power Clamp in same connection of drain >= 1800 um";
    CAPTION "3.3V/2.5V NMOS BigFET Lg only needs follow process rules.";
    ANTENNA ESD_PCL_HV_GATE_W_EXPc -lt "ESD_5_1g" -expr "  AREA(ESD_PCL_HV_GATE_W_EXPc)/GRID  " -rdb ESD.5.1g.rep ESD_PCL_HV_GATE_W_EXPc ; // -outputlayer _EPTMPL263594
}

RULE ESD.6g {
    CAPTION "Unit finger width of NMOS and PMOS for I/O buffer and power clamp device 15um <= width <= 60um.";
    PATH_LENGTH EGTE_W -ltgt 0 15 ; // -outputlayer _EPTMPL263595
    PATH_LENGTH EGTE_W -ltgt 60 999 ; // -outputlayer _EPTMPL263596
}

RULE ESD.8g {
    CAPTION "It is strictly prohitibied to butting or inserted substrat/well pickups for ESD N/PMOS.";
    OR EPACT ENACT -outputlayer EAct;
    OR NTAP PTAP -outputlayer DTap;
    SIZE EAct -by 3 -outside_of DTap -step "0.22*0.7" -outputlayer EActUp3;
    SELECT -interact DTap EActUp3 -outputlayer D1;
    SHRINK D1 -right 0.001 -outputlayer D1R1;
    NOT D1 D1R1 -outputlayer D1R2;
    EDGE_BOOLEAN -coincident_only D1 D1R2 -outputlayer D1R3;
    EDGE_LENGTH D1R3 -gt 0.001 -outputlayer D1R4;
    EXTE D1R4 EAct -lt 3 -abut -lt 90 -metric opposite -output positive1 -outputlayer D1R5;
    SELECT -with_edge D1 D1R5 -outputlayer D1L;
    SHRINK D1L -left 0.001 -outputlayer D1L1;
    NOT D1L D1L1 -outputlayer D1L2;
    EDGE_BOOLEAN -coincident_only D1L D1L2 -outputlayer D1L3;
    EDGE_LENGTH D1L3 -gt 0.001 -outputlayer D1L4;
    EXTE D1L4 EAct -lt 3 -abut -lt 90 -metric opposite -output positive1 -outputlayer D1L5;
    SELECT -with_edge D1L D1L5 -outputlayer D1X;
    SHRINK D1 -top 0.001 -outputlayer D1T1;
    NOT D1 D1T1 -outputlayer D1T2;
    EDGE_BOOLEAN -coincident_only D1 D1T2 -outputlayer D1T3;
    EDGE_LENGTH D1T3 -gt 0.001 -outputlayer D1T4;
    EXTE D1T4 EAct -lt 3 -abut -lt 90 -metric opposite -output positive1 -outputlayer D1T5;
    SELECT -with_edge D1 D1T5 -outputlayer D1B;
    SHRINK D1B -bottom 0.001 -outputlayer D1B1;
    NOT D1B D1B1 -outputlayer D1B2;
    EDGE_BOOLEAN -coincident_only D1B D1B2 -outputlayer D1B3;
    EDGE_LENGTH D1B3 -gt 0.001 -outputlayer D1B4;
    EXTE D1B4 EAct -lt 3 -abut -lt 90 -metric opposite -output positive1 -outputlayer D1B5;
    SELECT -with_edge D1B D1B5 -outputlayer D1Y;
    OR D1X D1Y -outputlayer DTap2Check;
    HOLES DTap2Check -inner -outputlayer DTapHole;
    SELECT -touch -not DTap2Check DTapHole -outputlayer DTapSuspect;
    SELECT -enclose_rect DTapSuspect -width 0.22 -length 20 ; // -outputlayer _EPTMPL263628
}

RULE ESD.18g_1.8V {
    CAPTION "Minimum 1.8V IO ESD NMOS/PMOS gate length >=0.25um";
    INTE LEGT -lt 0.25 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263629
}

RULE ESD.18g_3.3V_N {
    CAPTION "Minimum 3.3V IO ESD NMOS gate length >= 0.4um";
    INTE HEGN -lt 0.4 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263630
}

RULE ESD.18g_3.3V_P {
    CAPTION "Minimum 3.3V IO ESD PMOS gate length >= 0.3um";
    INTE HEGP -lt 0.3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263631
}

RULE ESD.19g {
    CAPTION "NMOS and PMOS of I/O buffer should have a nonsalicide area on drain side, that is, RPO mask should";
    CAPTION "block drain side of device (except contact region should keep silicided).";
    SELECT -inside EGTE EPMOS -outputlayer _EPTMPL263632;
    SELECT -interact EPSD RPO -outputlayer _EPTMPL263633;
    SELECT -interact -not _EPTMPL263632 _EPTMPL263633 ; // -outputlayer _EPTMPL263634
    SELECT -interact ENMOS RPO -outputlayer _EPTMPL263635;
    SELECT -inside EGTE _EPTMPL263635 -outputlayer _EPTMPL263636;
    SELECT -interact ENSD RPO -outputlayer _EPTMPL263637;
    SELECT -interact -not _EPTMPL263636 _EPTMPL263637 ; // -outputlayer _EPTMPL263638
}

RULE ESD.20g {
    CAPTION "For high voltage tolerant I/O designed by 3.3V/2.5V/1.8V/1.5V NMOS (see N1 and N2 in Fig.5b)";
    CAPTION "RPO should cover all inactive poly gates and extend to active region (Poly spacing==0.25um).";
    CAPTION "Minimum and maximum overlap from RPO to the active poly gate 0.05um or 0.06um";
    NOT ESD2_TOL_GATE RPO -outputlayer X;
    SELECT -interact -not ESD2_TOL X ; // -outputlayer _EPTMPL263640
    SELECT -outside ESD2_TOL_GATE2 RPO ; // -outputlayer _EPTMPL263641
    NOT ESD2_TOL_GATE1 RPO ; // -outputlayer _EPTMPL263642
    INTE ESD2_TOL_GATE2 RPO -lt 0.05 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263643
    SELECT -cut ESD2_TOL_GATE RPO -outputlayer ESD2_TOL_GATE_RPO;
    AND ESD2_TOL_GATE_RPO RPO -outputlayer ESD2_TOL_GATE_RPO_CH;
    SIZE ESD2_TOL_GATE_RPO_CH -by 0.025 -underover -outputlayer A;
    INTE A -lt 0.06 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263647
    SIZE A -by 0.03 -underover ; // -outputlayer _EPTMPL263648
}

RULE ESD.20g_A {
    CAPTION "For high voltage tolerant I/O designed by 3.3V/2.5V/1.8V/1.5V NMOS (see N1 and N2 in Fig.5b)";
    CAPTION "RPO should cover all inactive poly gates and extend to active region (Poly spacing==0.25um).";
    CAPTION "Minimum and maximum overlap from RPO to the active poly gate by 0.05um";
    SELECT -interact ENSD_NCO ESD2DMY -outputlayer X;
    INTE X -lt 0.25 -abut -lt 90 -output region ; // -outputlayer _EPTMPL263650
    SIZE X -by "0.25/2" -underover ; // -outputlayer _EPTMPL263651
}

RULE ESD.21g {
    CAPTION "For regular I/O designed by 5V, 3.3V, 2.5V, 1.8V and 1.5V NMOS (see N3 in Fig.6a)";
    CAPTION "Minimum and maximum overlap from RPO on the drain side to the active poly gate 0.05um or 0.06um";
    NOT ESD2_REG_GATE RPO -outputlayer X;
    SELECT -interact -not ESD2_REG X ; // -outputlayer _EPTMPL263653
    SELECT -outside ESD2_REG_GATE RPO ; // -outputlayer _EPTMPL263654
    INTE ESD2_REG_GATE RPO -lt 0.05 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263655
    SELECT -cut ESD2_REG_GATE RPO -outputlayer ESD2_REG_GATE_RPO;
    AND ESD2_REG_GATE_RPO RPO -outputlayer ESD2_REG_GATE_RPO_CH;
    SIZE ESD2_REG_GATE_RPO_CH -by 0.025 -underover -outputlayer A;
    INTE A -lt 0.06 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263659
    SIZE A -by 0.03 -underover ; // -outputlayer _EPTMPL263660
}

RULE ESD.24g {
    CAPTION "The minimum width of RPO on drain side (X) for 5V,3.3V, 2.5V, 1.8V and 1.5V NMOS and PMOS.";
    CAPTION "exclude 1.8V and 1.5V NMOS when used as power clamp device>=1.95um";
    OR ENSD_WCO EPSD_WCO -outputlayer _EPTMPL263661;
    AND _EPTMPL263661 ESD2DMY -outputlayer _EPTMPL263662;
    AND _EPTMPL263662 RPO -outputlayer X;
    EDGE_BOOLEAN -coincident_only -outside EGTE X -outputlayer Y;
    EDGE_BOOLEAN -coincident_only -inside RPO X -outputlayer Z;
    ENC Y Z -lt 1.95 -abut -lt 90 -output region ; // -outputlayer _EPTMPL263666
}

RULE ESD.25g {
    CAPTION "The minimum clearance from poly edge to CO edge on source side for NMOS and PMOS (Except ESD.26g)>=0.5um";
    OR ENMOS EPMOS -outputlayer _EPTMPL263667;
    SELECT -interact _EPTMPL263667 RPO -outputlayer _EPTMPL263668;
    AND ECOS _EPTMPL263668 -outputlayer X;
    EXTE X EGTE_W -lt 0.5 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263670
    AND ECO ESD1_NCS -outputlayer Y;
    EXTE Y EGTE_W -lt 0.5 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263672
}

RULE ESD.26g {
    CAPTION "The minimum clearance of poly edge to CO edge on D/S side for 3.3V/2.5V/1.8V and 1.5V power clamp device>=0.25um";
    SELECT -interact -not ENMOS RPO -outputlayer _EPTMPL263673;
    AND ECO _EPTMPL263673 -outputlayer X;
    EXTE X EGTE_W -lt 0.25 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263675
}

RULE ESD.27g {
    CAPTION "For RPO DRC purpose,we need a dummy layers in ESD protection device.layers should cover all ESD protection devices.";
    CAPTION "ESD2DMY is for the cascade NMOS in high voltage tolerant I/O designed by 3.3V/2.5V NMOS (see Fig.5b), regular IO designed by";
    CAPTION "5V/3.3V/2.5V/1.8V/1.5V NMOS and PMOS (see Fig.6b), power clmap designed by 5V/3.3V/2.5V NMOS.";
    SELECT -cut EGTE RPO -outputlayer X;
    SELECT -enclose ENMOS X -outputlayer _EPTMPL263677;
    SELECT -inside EGTE _EPTMPL263677 -outputlayer _EPTMPL263678;
    NOT _EPTMPL263678 ESD2DMY ; // -outputlayer _EPTMPL263679
    SELECT -enclose EPMOS X -outputlayer _EPTMPL263680;
    SELECT -inside EGTE _EPTMPL263680 -outputlayer _EPTMPL263681;
    NOT _EPTMPL263681 ESD2DMY ; // -outputlayer _EPTMPL263682
}

RULE ESD.28g {
    CAPTION "ESD implant is required for High Voltage Tolerant I/O designed by 3.3V NMOS device for 5V signal";
    CAPTION "input or 2.5V NMOS device for 3.3V signal input at I/O pad. ESD mask (No. 111) can be generated by";
    CAPTION "logical operation. It is not allowed to use ESD mask (No. 111) for 5V NMOS device.";
    CAPTION "ESD3DMY or ESDIMP is for the cascade NMOS in high voltage tolerant I/O designed by 3.3V/2.5V NMOS (see Fig.5b).";
    SELECT -enclose ENMOS LEGT -outputlayer _EPTMPL263683;
    SELECT -interact _EPTMPL263683 ESD2DMY -outputlayer _EPTMPL263684;
    OR ESD3DMY ESDIMP -outputlayer _EPTMPL263685;
    SELECT -interact _EPTMPL263684 _EPTMPL263685 ; // -outputlayer _EPTMPL263686
    AND ESD2_TOL_GATE OD2 -outputlayer _EPTMPL263687;
    SELECT -enclose ENMOS _EPTMPL263687 -outputlayer _EPTMPL263688;
    NOT _EPTMPL263688 ESD3DMY -outputlayer _EPTMPL263689;
    SELECT -interact -not _EPTMPL263689 ESDIMP ; // -outputlayer _EPTMPL263690
    AND ESD3DMY GATE_PP ; // -outputlayer _EPTMPL263691
    SELECT -interact ESDIMP EPMOS ; // -outputlayer _EPTMPL263692
}

RULE ESD.30g {
    CAPTION "For regular 1.8V I/O in NMOS region : Minumum clearance from RPO to poly spacing >=0.45um.";
    EXTE RPO1 EGTE1_W -lt 0.45 -abut -lt 90 -metric opposite -output region ; // -outputlayer _EPTMPL263693
    AND EGTE1 RPO1 ; // -outputlayer _EPTMPL263694
}

RULE ESD.32g {
    CAPTION "The minimum width of RPO on drain side (X) for 1.8V NMOS and 5V/3.3V/1.8V/1.5V PMOS.>=1.5um";
    EDGE_BOOLEAN -inside RPO1 OD -outputlayer Y;
    INTE Y -lt 1.5 -abut -lt 90 -output region ; // -outputlayer _EPTMPL263696
}

RULE ESD.34g {
    CAPTION "5V, 3.3V and 2.5V NMOS devices when used as power clamp devices, the RPO can fully cover the";
    CAPTION "uncontacted poly gate, source/drain (except contact region should keep silicided).";
    SELECT -interact ENMOS ESD1DMY -outputlayer _EPTMPL263697;
    NOT _EPTMPL263697 ERPOA ; // -outputlayer _EPTMPL263698
}
SELECT -interact OD EGTE -outputlayer _EPTMPL263699;
NOT _EPTMPL263699 POLY -outputlayer _EPTMPL263700;
AND _EPTMPL263700 ESD1DMY -outputlayer NCS_SD_1;
STAMP NCS_SD_1 NSDi -outputlayer NCS_SD;
ANTENNA NCS_SD PTAPi -gt 0 -outputlayer NCS_S;
NOT NCS_SD NCS_S -outputlayer NCS_D;

RULE ESD.35g {
    CAPTION "Minimum width of RPO on drain side (X) for 5V, 3.3V and 2.5V NMOS devices when used as power clamp";
    CAPTION "devices. Ncs Drain is defined as (((OD INTERACT GATE) NOT PO) AND ESD1DMY)";
    CAPTION "which not connect to PW Pickup.>=1.95um";
    AND NCS_D RPO -outputlayer X;
    EDGE_BOOLEAN -coincident_only -outside EGTE NCS_D -outputlayer Y;
    EDGE_BOOLEAN -coincident_only -inside RPO X -outputlayer Z;
    ENC Y Z -lt 1.95 -abut -lt 90 -output region ; // -outputlayer _EPTMPL263708
}

RULE ESD.37g {
    CAPTION " For RPO DRC purpose, we need a dummy layers for 5V, 3.3Vand 2.5V NMOS devices when used as power";
    CAPTION " clamp devices. The layers should cover all ESD protection devices.";
    SELECT -inside -not EGTE RPO -outputlayer X;
    SELECT -enclose -not ENMOS X -outputlayer Y;
    SELECT -interact -not Y ESD1DMY ; // -outputlayer _EPTMPL263711
    AND ESD1DMY GATE_PP ; // -outputlayer _EPTMPL263712
    SELECT -enclose ENMOS ESD1_GATE -outputlayer _EPTMPL263713;
    SELECT -inside EGTE _EPTMPL263713 -outputlayer _EPTMPL263714;
    NOT _EPTMPL263714 ESD1DMY ; // -outputlayer _EPTMPL263715
}

RULE ESD.WARN.1 {
    CAPTION "CO can't inserted between gate and RPO for 1.8V NMOS and all PMOS I/O pattern.";
    OR EPSD ENSD -outputlayer _EPTMPL263716;
    SELECT -interact _EPTMPL263716 RPO1 -outputlayer RED;
    NOT RED RPO1 -outputlayer XRPO;
    SELECT -touch XRPO EGTE1 -outputlayer XRPG;
    SELECT -interact XRPG ECO ; // -outputlayer _EPTMPL263720
}

RULE ESD.WARN.3 {
    CAPTION "ESD is not allowed in processes except 5V.";
    COPY ESD ; // -outputlayer _EPTMPL263721
}

RULE ESD.WARN.5 {
    CAPTION "SDI encloure of LV ACTIVE >= 0";
    SELECT -interact DACT SDI -outputlayer _EPTMPL263722;
    NOT _EPTMPL263722 SDI ; // -outputlayer _EPTMPL263723
}

RULE ESD.40g {
    CAPTION "It is not allowed to use OD resistors or NW resistors connected to IO PAD";
    SELECT -interact NWELi RWDMY -outputlayer _EPTMPL263724;
    NOT _EPTMPL263724 RWDMY -outputlayer NWR_T;
    STAMP NWR_T COk -outputlayer NWRkT;
    AND ODRES_ALL RPDUMMY -outputlayer ODRES_a;
    NOT OD POLY -outputlayer _EPTMPL263728;
    SELECT -interact _EPTMPL263728 ODRES_a -outputlayer _EPTMPL263729;
    NOT _EPTMPL263729 ODRES_a -outputlayer ODR_T;
    STAMP ODR_T COk -outputlayer ODRkT;
    ANTENNA ODRkT IO_CBk IO_UBMnk IO_UBMdk -gt 0 -expr "  !!AREA(ODRkT)*(!!AREA(IO_CBk)+!!AREA(IO_UBMnk)+!!AREA(IO_UBMdk))  " ; // -outputlayer _EPTMPL263732
    ANTENNA NWRkT IO_CBk IO_UBMnk IO_UBMdk -gt 0 -expr "  !!AREA(NWRkT)*(!!AREA(IO_CBk)+!!AREA(IO_UBMnk)+!!AREA(IO_UBMdk))  " ; // -outputlayer _EPTMPL263733
}
variable HIA_1g 2;
variable HIA_2g 10;
variable HIA_3g 300;
variable HIA_4g 0.28;
variable HIA_5g 0.28;
SELECT -outside -not PTAP HIADMY -outputlayer HIA_NAnode;
SELECT -inside PACT HIADMY -outputlayer HIA_PAnode;
SELECT -inside NACT HIADMY -outputlayer HIA_NCathode;
SELECT -outside -not NTAP HIADMY -outputlayer HIA_PCathode;
OR HIA_NAnode HIA_PAnode -outputlayer HIA_Anode;
OR HIA_NCathode HIA_PCathode -outputlayer HIA_Cathode;

RULE HIA.1g {
    CAPTION "Width of N+ Active (N-HIA diode's cathode) and P+ Active (P-HIA diode's anode) inside HIA_DUMMY. (Figure XXX and Figure XXX) <= 2";
    WITH_WIDTH HIA_NCathode -gt "HIA_1g" ; // -outputlayer _EPTMPL263740
    WITH_WIDTH HIA_PAnode -gt "HIA_1g" ; // -outputlayer _EPTMPL263741
}

RULE HIA.2g {
    CAPTION "Length of N+ Active (N-HIA diode's cathode) and P+ Active (P-HIA diode's anode) inside HIA_DUMMY. (Figure XXX and Figure XXX) <= 10";
    SELECT -enclose_rect HIA_NCathode -width 0.1 -length HIA_2g+GRID -orthogonal_only ; // -outputlayer _EPTMPL263742
    SELECT -enclose_rect HIA_PAnode -width 0.1 -length HIA_2g+GRID -orthogonal_only ; // -outputlayer _EPTMPL263743
}
SELECT -interact HIA_NCathode SD_IOPAD -outputlayer HIA_NCathode_IO_PAD;
SELECT -interact HIA_PAnode SD_IOPAD -outputlayer HIA_PAnode_IO_PAD;
STAMP HIA_NCathode_IO_PAD NSDi -outputlayer NHIA_ESD_IO_PAD;
STAMP HIA_PAnode_IO_PAD PSDi -outputlayer PHIA_ESD_IO_PAD;

RULE HIA.3g {
    CAPTION "Total perimeter of each N+ or P+ ACTIVE inside HIA_dummy in same connection of I/O PAD. (Figure XXX and Figure XXX). The perimeter counts the drawn anode junction parameter region ex. The drawing OD perimeter dimension of active inside HIA_DUMMY= (A+B)*2*N >= 300";
    ANTENNA NHIA_ESD_IO_PAD -lt "HIA_3g" -expr "  PERIM(NHIA_ESD_IO_PAD)  " -rdb HIA_3G_N.rep NHIA_ESD_IO_PAD ; // -outputlayer _EPTMPL263748
    ANTENNA PHIA_ESD_IO_PAD -lt "HIA_3g" -expr "  PERIM(PHIA_ESD_IO_PAD)  " -rdb HIA_3G_P.rep PHIA_ESD_IO_PAD ; // -outputlayer _EPTMPL263749
}

RULE HIA.4g {
    CAPTION "The OD spacing of longer side of anode (P-diode) between anode and cathode, and vice versa for (N-diode). >= 0.28";
    EXTE HIA_NCathode HIA_NAnode -lt "HIA_4g" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263750
    EXTE HIA_PCathode HIA_PAnode -lt "HIA_4g" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263751
}

RULE HIA.9g {
    CAPTION "HIA_DUMMY enclosure of OD >= 0";
    EDGE_BOOLEAN -inside HIADMY OD ; // -outputlayer _EPTMPL263752
}

RULE HIA.17g {
    CAPTION "ALL ACTIVE OD inside same HIA_DUMMY should be in the same net";
    SELECT -interact HIADMY NSDi -gt 1 -by_net ; // -outputlayer _EPTMPL263753
    SELECT -interact HIADMY PSDi -gt 1 -by_net ; // -outputlayer _EPTMPL263754
}

RULE HIA.18g {
    CAPTION "HIA Dummy must be covered by DIODMY";
    NOT HIADMY DIODUMMY ; // -outputlayer _EPTMPL263755
}

RULE ESDIMP.W.1 {
    CAPTION "Minimum esdimp width >= 0.6";
    INTE ESDIMP -lt "ESDIMP_W_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263756
}

RULE ESDIMP.S.1 {
    CAPTION "Minimum esdimp space >= 0.6";
    EXTE ESDIMP -lt "ESDIMP_S_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263757
}

RULE ESDIMP.S.2 {
    CAPTION "Minimum space to esd3dmy (Overlap is prohibited) >= 0.6";
    EXTE ESDIMP ESD3DMY -lt "ESDIMP_S_2" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263758
    AND ESDIMP ESD3DMY ; // -outputlayer _EPTMPL263759
}

RULE ESDIMP.EN.1 {
    CAPTION "(OD not POLY) enclosure of esdimp (esdimp must be fully inside (OD not POLY)) >= 0.4";
    NOT OD POLY -outputlayer A;
    ENC ESDIMP A -lt "ESDIMP_EN_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL263761
    NOT ESDIMP A ; // -outputlayer _EPTMPL263762
}

RULE ESDIMP.A.1 {
    CAPTION "Minimum esdimp area >= 1";
    AREA ESDIMP -lt "ESDIMP_A_1" ; // -outputlayer _EPTMPL263763
}

RULE ESDIMP.A.2 {
    CAPTION "Minimum esdimp enclosed area >= 1";
    HOLES ESDIMP -inner -outputlayer _EPTMPL263764;
    NOT _EPTMPL263764 ESDIMP -outputlayer A;
    AREA A -lt "ESDIMP_A_2" ; // -outputlayer _EPTMPL263766
}

RULE ESDIMP.R.1 {
    CAPTION "esdimp must be fully inside N+ active";
    NOT ESDIMP NACT ; // -outputlayer _EPTMPL263767
}
