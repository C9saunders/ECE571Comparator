RULE M2.E.1 {
    CAPTION "Min. extension of a M2 region beyond a VIA1 region < 0.01";
    ENC VIA1 M2 -lt 0.01 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262843
    NOT VIA1 M2 ; // -outputlayer _EPTMPL262844
