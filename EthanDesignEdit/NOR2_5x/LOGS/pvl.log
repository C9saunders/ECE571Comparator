}

RULE M1.A.1 {
    CAPTION "Min. M1 area < 0.202";
    AREA M1_A -lt "M1_A_1" ; // -outputlayer _EPTMPL262777
}
NOT VIA1 SR_VIA1 -outputlayer VIA1_CORE;

RULE VIA1.W.1 {
    CAPTION "VIA1 must be 0.26 x 0.26";
