    NOT SBDDMY X -outputlayer Y;
    SELECT -interact PPOD_SBD Y ; // -outputlayer _EPTMPL264516
}

RULE SBD.R.3 {
    CAPTION "The each NW of SBD should be surrounded by the P+ Guard Ring (P+ pickup ring).";
    NOT NW_SBD PPOD_SBD_H ; // -outputlayer _EPTMPL264517
    SELECT -interact PPOD_SBD_H SBDOD_ALL -gt 1 ; // -outputlayer _EPTMPL264518
    SELECT -interact PPOD_SBD_H NW_SBD -gt 1 ; // -outputlayer _EPTMPL264519
