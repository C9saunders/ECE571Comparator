    GROW _EPTMPL262765 -bottom 5 -outputlayer M1_G5;
    AND M1_G5 M1 -outputlayer M1_Wide;
    STAMP M1_Wide M1xd -outputlayer M1_WideC;
    EXTE M1_WideC -lt "M1_S_2_2" -connected -metric opposite -output region -outputlayer M1_S_REG;
