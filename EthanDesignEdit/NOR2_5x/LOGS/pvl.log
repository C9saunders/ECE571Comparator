ENC MOM_M1_SIDE_EDGE_FULL MOM_M1_SPACE_90_90_2 -lt "GRID" -abut -eq 90 -intersecting only -output positive1 -outputlayer _EPTMPL264720;
EDGE_SELECT -coincident_only -inside MOM_M1_SIDE_EDGE_FULL _EPTMPL264720 -outputlayer _EPTMPL264721;
EDGE_BOOLEAN -coincident_only -inside MOM_M1_SIDE_EDGE _EPTMPL264721 -outputlayer LAST_M1_METAL_EDGE_pre;
OR_EDGE MOM_M1_SPACE_90_90_1 MOM_M1_SPACE_90_90_2 -outputlayer _EPTMPL264723;
EDGE_EXPAND _EPTMPL264723 -inside_by "GRID" -outputlayer _EPTMPL264724;
BBOX _EPTMPL264724 -outputlayer _EPTMPL264725;
EDGE_BOOLEAN -inside LAST_M1_METAL_EDGE_pre _EPTMPL264725 -outputlayer LAST_M1_METAL_EDGE;
EDGE_BOOLEAN -coincident_only -not MOM_M1_SPACE_90_90 MOM_M1_SPACE_90_90_1 -outputlayer MOM_M1_SPACE_90_90_3;
CONVEX_EDGE MOM_M1_SPACE -angle1 -eq 90 -angle2 -eq 270 -outputlayer MOM_M1_SPACE_90_270;
OR_EDGE MOM_M1_SPACE_90_90_3 MOM_M1_SPACE_90_270 -outputlayer _EPTMPL264729;
EDGE_EXPAND _EPTMPL264729 -inside_by "GRID" -outputlayer _EPTMPL264730;
