RULE AN.R.40m_M1 {
    CAPTION "For the critical differential pair inside MATCHING layer, asymmetry metal (M1) shielding is not allowed.";
    CAPTION "DRC only flag: (1) One of differential pair covered by metal layer but without fully covered.";
    CAPTION "(2) One device of the differential pair fully covered by metal layer and the other is not fully covered.";
    SELECT -interact MATCHING POLY_PAIR_CHECK_B_M1 ; // -outputlayer _EPTMPL264618
    SELECT -interact MATCHING POLY_PAIR_CHECK_G_M1 -outputlayer _EPTMPL264619;
