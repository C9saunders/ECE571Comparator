}

RULE M1.S.1 {
    CAPTION "Min. M1 space < 0.23";
    EXTE M1 -lt 0.23 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262717
}

RULE M1.S.2 {
    CAPTION "Min. space to wide M1 (>10um) < 0.6";
    SHRINK M1 -right 5 -outputlayer _EPTMPL262718;
    SHRINK _EPTMPL262718 -left 5 -outputlayer _EPTMPL262719;
    SHRINK _EPTMPL262719 -top 5 -outputlayer _EPTMPL262720;
    SHRINK _EPTMPL262720 -bottom 5 -outputlayer M1_S5;
    GROW M1_S5 -right 5 -outputlayer _EPTMPL262722;
    GROW _EPTMPL262722 -left 5 -outputlayer _EPTMPL262723;
    GROW _EPTMPL262723 -top 5 -outputlayer _EPTMPL262724;
    GROW _EPTMPL262724 -bottom 5 -outputlayer M1_G5;
    AND M1_G5 M1 -outputlayer M1_Wide;
    SIZE M1_Wide -by 1 -inside_of M1 -step 0.161 -outputlayer M1_Exp;
    NOT M1_Exp M1_Wide -outputlayer M1_Branch;
    EDGE_BOOLEAN -coincident_only -inside M1_Branch M1 -outputlayer M1_Branch_edge;
    SIZE M1_Exp -by "M1_S_2" -outputlayer _EPTMPL262730;
