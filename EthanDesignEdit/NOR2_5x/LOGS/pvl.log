    STAMP M1_Check M1xd -outputlayer M1_CheckC;
    STAMP M1_Branch M1xd -outputlayer M1_BranchC;
    STAMP M1_Branch_Check M1xd -outputlayer M1_Branch_CheckC;
    EXTE M1_WideC M1_CheckC -lt "M1_S_2" -abut -ltgt 0 89.5 -not_connected -output region ; // -outputlayer _EPTMPL262738
    EXTE M1_BranchC M1_Branch_CheckC -lt "M1_S_2" -abut -ltgt 0 89.5 -not_connected -output region ; // -outputlayer _EPTMPL262739
}

RULE M1.S.2.1.a {
    CAPTION "Min. space betweem wide metal and small piece of metal with parallel run length >= 35 and same connection >=0.6 um";
    SHRINK M1 -right 5 -outputlayer _EPTMPL262740;
    SHRINK _EPTMPL262740 -left 5 -outputlayer _EPTMPL262741;
    SHRINK _EPTMPL262741 -top 5 -outputlayer _EPTMPL262742;
    SHRINK _EPTMPL262742 -bottom 5 -outputlayer M1_S5;
    GROW M1_S5 -right 5 -outputlayer _EPTMPL262744;
    GROW _EPTMPL262744 -left 5 -outputlayer _EPTMPL262745;
    GROW _EPTMPL262745 -top 5 -outputlayer _EPTMPL262746;
    GROW _EPTMPL262746 -bottom 5 -outputlayer M1_G5;
    AND M1_G5 M1 -outputlayer M1_Wide;
    NOT M1 M1_Wide -outputlayer M1_Small;
    STAMP M1_Wide M1xd -outputlayer M1_WideC;
    STAMP M1_Small M1xd -outputlayer M1_SmallC;
    EXTE M1_WideC M1_SmallC -lt "M1_S_2_1" -connected -metric opposite -output region -measure all -outputlayer M1_S_REG;
    SELECT -enclose_rect M1_S_REG -width GRID -length M1_S_2_L -outputlayer M1_S_REG_CHECK;
    EDGE_BOOLEAN -coincident_only -outside M1_S_REG_CHECK M1_Wide -outputlayer WideEdge1;
    EDGE_BOOLEAN -coincident_only -inside M1_Small M1 -outputlayer M1_Small_Edge;
    EDGE_BOOLEAN -coincident_only -outside M1_S_REG_CHECK M1_Small_Edge -outputlayer WideEdge2;
    PATH_LENGTH WideEdge1 -ge "M1_S_2_L" ; // -outputlayer _EPTMPL262757
    PATH_LENGTH WideEdge2 -ge "M1_S_2_L" ; // -outputlayer _EPTMPL262758
}

RULE M1.S.2.1.b {
    CAPTION "Min. space between two wide metals with parallel run length >= 35 and same connection >=0.6 um";
    SHRINK M1 -right 5 -outputlayer _EPTMPL262759;
