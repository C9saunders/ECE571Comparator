    XOR Y NW_SBD ; // -outputlayer _EPTMPL264506
}

RULE SBD.E.2 {
    CAPTION "Minimum and maximum extension of a PP region beyond";
    CAPTION "an enclosed P+ active OD region of the SBD.==0.22um";
