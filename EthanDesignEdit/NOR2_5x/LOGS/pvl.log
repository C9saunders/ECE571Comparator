RULE OD.R.1 {
    CAPTION "{OD or DOD} local density (minimum) over window 500 um x 500 um stepping OD_R_Sum >= 0.2";
    CAPTION "For OD.R.1, the following regions can be excluded:";
    CAPTION "  a.(CB sizing 2) for high speed/RF products";
    CAPTION "  b.ODBLK /RWDMY/FW/LMARK/LOGO/INDDMY as default";
    CAPTION "  c.Chip corner stress relief area if seal-ring & stress relief pattern added by TSMC";
    CAPTION "This rule is applied while the area (checking window - the above excluded region) >= 1/4 checking window area";
    NOT ODx OD_EXC -outputlayer N;
    NOT CHIP OD_EXC -outputlayer D;
    NOT CHIPx OD_EXC -outputlayer A;
    DENSITY A ODx CHIP N D -lt OD_R_1 -window "OD_R_W" -step "OD_R_S" -backup -inside_of layer CHIPx -print "OD.R.1.density" -rdb OD.R.1.RDB.density -expr "  ~(AREA(A)-OD_R_A)*!!(AREA(A)-OD_R_A)+AREA(N)/AREA(D)+!~(AREA(ODx)/AREA(CHIP)-OD_R_1)+!(AREA(ODx)/AREA(CHIP)-OD_R_1)  " -outputlayer X;
    COPY X ; // -outputlayer _EPTMPL264571
}

RULE OD.R.2 {
    CAPTION "{OD or DOD} local density (maximum) over window 500 um x 500 um stepping OD_R_Sum <= 0.8";
    CAPTION "For OD.R.2, the following regions can be excluded:";
    CAPTION "  a.(CB sizing 2) for high speed/RF products";
    CAPTION "  b.ODBLK /RWDMY/FW/LMARK/LOGO/INDDMY as default";
    CAPTION "  c.Chip corner stress relief area if seal-ring & stress relief pattern added by TSMC";
    CAPTION "This rule is applied while the area (checking window - the above excluded region) >= 1/4 checking window area";
    NOT ODx OD_EXC -outputlayer N;
    NOT CHIP OD_EXC -outputlayer D;
    NOT CHIPx OD_EXC -outputlayer A;
    DENSITY A ODx CHIP N D -gt OD_R_2 -window "OD_R_W" -step "OD_R_S" -backup -inside_of layer CHIPx -print "OD.R.2.density" -rdb OD.R.2.RDB.density -expr "  ~(OD_R_A-AREA(A))*AREA(N)/AREA(D)*!~(AREA(ODx)/AREA(CHIP)-OD_R_2)  " -outputlayer X;
    COPY X ; // -outputlayer _EPTMPL264576
}

RULE DOD.R.3 {
    CAPTION "The only shapes allowed are square(or rectangular) and solid";
    HOLES DOD ; // -outputlayer _EPTMPL264577
