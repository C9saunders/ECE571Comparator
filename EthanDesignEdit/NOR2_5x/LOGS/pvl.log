    EDGE_BOOLEAN -coincident_only -outside -not PPOD_SBD_W NPOD_SBD_G ; // -outputlayer _EPTMPL264496
}

RULE SBD.S.1 {
    CAPTION "Space between P+ active OD region and NP OD region of the SBD ==0.48um";
    EXTE PPOD_SBD NPOD_SBD -lt 0.48 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL264497
    SELECT -interact PPOD_SBD NPOD ; // -outputlayer _EPTMPL264498
    SELECT -touch -not PPOD_SBD PPOD_SBD_G -eq 2 ; // -outputlayer _EPTMPL264499
    SELECT -touch PPOD_SBD PPOD_SBD_G -eq 2 -outputlayer A;
    EDGE_SELECT -coincident_only -outside A PPOD_SBD_G -outputlayer B;
    INTE B -lt 0.48 -abut -eq 90 -intersecting ONLY -output region -outputlayer C;
    SELECT -interact PPOD_SBD C ; // -outputlayer _EPTMPL264503
}

RULE SBD.E.1 {
    CAPTION "Minimum and maximum extension from NW edge to an OD";
    CAPTION "region used for the SBD. ==0.80um";
