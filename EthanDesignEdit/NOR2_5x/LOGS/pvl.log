    ENC X NP -lt 0.001 -abut -eq 0 -output positive1 -outputlayer Y;
    EDGE_EXPAND Y -outside_by 0.001 -outputlayer Z;
    SELECT -interact -not Z PPOD -outputlayer _EPTMPL262655;
    SELECT -interact -not _EPTMPL262655 SEALRING_ALL ; // -outputlayer _EPTMPL262656
}

RULE NP.E.3 {
    CAPTION "Minimum enclosure of NTAP by NP < 0.02 with PWEL space >= 0.43";
    ENC NTAP NP -lt 0.02 -abut -ltgt 0 90 -single_point -output region ; // -outputlayer _EPTMPL262657
    ENC NTAP NP -lt 0.001 -abut -eq 0 -output positive1 -outputlayer X;
    EDGE_EXPAND X -outside_by 0.001 -outputlayer Y;
    SELECT -interact -not Y PPOD ; // -outputlayer _EPTMPL262660
}

RULE NP.E.4 {
    CAPTION "Min. enc. of NTAP by NP < 0.18 with PWEL space < 0.43";
    EDGE_BOOLEAN -outside NPE4_CHECKOD NPE4_NWELC ; // -outputlayer _EPTMPL262661
}

RULE NP.A.1 {
    CAPTION "Minimum area of NP < 0.3844";
    AREA NP -lt 0.3844 ; // -outputlayer _EPTMPL262662
}

RULE NP.E.6 {
    CAPTION "Min enc of POLY resistor by NP < 0.18";
    ENC PORES NP -lt 0.18 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262663
}
HOLES CB -outputlayer CB_HOLE;
SELECT -touch CB CB_HOLE -eq 1 -outputlayer CB_SR;
SELECT -interact -not RPO CB_SR -outputlayer RPO_NOT_SR;

RULE RPO.W.1 {
    CAPTION "Minimum RPO width < 0.43";
    INTE RPO -lt 0.43 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262667
}

RULE RPO.S.1 {
    CAPTION "Minimum RPO space < 0.43";
    EXTE RPO -lt "RPO_S_1" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262668
}

RULE RPO.C.1 {
    CAPTION "Minimum RPO space to OD < 0.22 except SEALRING region";
    EXTE RPO OD -lt 0.22 -abut -lt 90 -single_point -output region -outputlayer _EPTMPL262669;
    SELECT -interact -not _EPTMPL262669 SEALRING_ALL ; // -outputlayer _EPTMPL262670
}

RULE RPO.C.2 {
    CAPTION "Minimum RPO space to CO < 0.22";
    EXTE RPO CO -lt "RPO_C_2" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262671
    AND CO RPO ; // -outputlayer _EPTMPL262672
}

RULE RPO.C.3 {
    CAPTION "Minimum RPO space to gate < 0.45";
    CAPTION "exclude ESD part";
    NOT ALL_GATE DRCDMY -outputlayer _EPTMPL262673;
    NOT _EPTMPL262673 ESD1DMY -outputlayer _EPTMPL262674;
    NOT _EPTMPL262674 ESD2DMY -outputlayer _EPTMPL262675;
    NOT _EPTMPL262675 ESD3DMY -outputlayer _EPTMPL262676;
    NOT _EPTMPL262676 SDI -outputlayer A;
    EXTE RPO A -lt 0.45 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262678
    AND RPO A ; // -outputlayer _EPTMPL262679
}

RULE RPO.C.4 {
    CAPTION "Minimum RPO overhang OD < 0.22";
    ENC OD RPO -lt 0.22 -abut -lt 90 -single_point -output region -outputlayer _EPTMPL262680;
    SELECT -interact -not _EPTMPL262680 SEALRING_ALL ; // -outputlayer _EPTMPL262681
    SELECT -inside RPO_NOT_SR OD ; // -outputlayer _EPTMPL262682
}

RULE RPO.E.1 {
    CAPTION "Minimum OD overhang RPO < 0.22";
    ENC RPO OD -lt 0.22 -abut -lt 90 -single_point -output region -outputlayer _EPTMPL262683;
    SELECT -interact -not _EPTMPL262683 SEALRING_ALL ; // -outputlayer _EPTMPL262684
}

RULE RPO.C.5 {
    CAPTION "Minimum RPO overhang POLY < 0.22";
    ENC POLY RPO -lt 0.22 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262685
    SELECT -inside RPO_NOT_SR POLY ; // -outputlayer _EPTMPL262686
}

RULE RPO.C.6 {
    CAPTION "Minimum clearance RPO to unrelated poly < 0.3um";
    EXTE RPO POLY_ISO -lt 0.3 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262687
}

RULE RPO.A.1 {
    CAPTION "RPO min. area < 2 um*um";
    AREA RPO -lt 2 ; // -outputlayer _EPTMPL262688
}
variable RPO_A_2pre " ((RPO_A_2 + (RPO_S_1 * RPO_S_1 * 3.142))/(2 * RPO_S_1))   *((RPO_A_2 + (RPO_S_1 * RPO_S_1 * 3.142))/(2 * RPO_S_1))/3.141 ";

RULE RPO.A.2 {
    CAPTION "Enclosed Area >= 1 um2";
    HOLES RPO -inner -lt "RPO_A_2pre" -outputlayer A;
    NOT A RPO -outputlayer B;
    AREA B -lt "RPO_A_2" ; // -outputlayer _EPTMPL262691
}

RULE CO.W.1 {
    CAPTION "contact width != 0.22";
    NOT CO SR_CO -outputlayer X;
    RECT_CHK -not X -eq 0.22 -by -eq 0.22 -orthogonal_only ; // -outputlayer _EPTMPL262693
}

RULE CO.S.1 {
    CAPTION "contact spacing < 0.25";
    EXTE CO -lt 0.25 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262694
}

RULE CO.S.2 {
    CAPTION "Min space between two contacts in larger than 4x4 array.";
    SIZE CO -by "0.30/2" -overunder -outputlayer A;
    SIZE A -by 0.7 -underover -outputlayer B;
    SELECT -interact B CO -ge 16 -outputlayer C;
    SELECT -interact CO C -outputlayer D;
    EXTE D -lt 0.28 ; // -outputlayer _EPTMPL262699
}

RULE CO.C.1_CO.R.1 {
    CAPTION "diff contact to gate space < 0.16, or contact on gate";
    EXTE CO_DIFF ALL_GATE -lt 0.16 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262700
    AND CO_DIFF ALL_GATE ; // -outputlayer _EPTMPL262701
}

RULE CO.C.2 {
    CAPTION "poly contact space to OD < 0.20";
    EXTE CO_POLY OD -lt 0.2 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262702
}

RULE CO.E.1 {
    CAPTION "Minimum extension of an OD region beyond a CO region >= 0.1 um";
    ENC CO_DIFF OD -lt 0.1 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262703
    EDGE_BOOLEAN -outside CO_DIFF OD ; // -outputlayer _EPTMPL262704
}

RULE CO.E.2 {
    CAPTION "poly olap contact < 0.10";
    ENC CO_POLY POLY_ISO -lt 0.1 -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262705
    SELECT -cut CO_POLY POLY_ISO ; // -outputlayer _EPTMPL262706
}

RULE CO.E.3 {
    CAPTION "Minimum extension of a PP region beyond a OD CO region must >= 0.12 um except SBD region";
    ENC CO_DIFF PP_NSBD -lt "CO_E_3" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262707
    EDGE_BOOLEAN -inside PP_NSBD CO_DIFF ; // -outputlayer _EPTMPL262708
}

RULE CO.E.4 {
    CAPTION "implant olap contact < 0.12";
    ENC CO_DIFF NP -lt "CO_E_4" -abut -lt 90 -single_point -output region ; // -outputlayer _EPTMPL262709
    EDGE_BOOLEAN -inside NP CO_DIFF ; // -outputlayer _EPTMPL262710
}

RULE CO.R.4 {
    CAPTION "CO and {PO INTERACT(RPDMY(54,0) OR RPDMY(drawing1)(54,1) OR RLPPDMY)} must be fully covered by {NP OR PP}";
    OR RPDUMMY RLPPDMY -outputlayer _EPTMPL262711;
    SELECT -interact POLY _EPTMPL262711 -outputlayer _EPTMPL262712;
    AND CO _EPTMPL262712 -outputlayer A;
    OR NP PP -outputlayer _EPTMPL262714;
    NOT A _EPTMPL262714 ; // -outputlayer _EPTMPL262715
}

RULE M1.W.1 {
    CAPTION "Min. M1 width < 0.23";
