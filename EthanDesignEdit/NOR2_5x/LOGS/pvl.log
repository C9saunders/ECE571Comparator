    XOR X PP_SBD_ALL ; // -outputlayer _EPTMPL264508
}

RULE SBD.O.1 {
    CAPTION "Minimum and maximum overlap from a PP edge to a P+";
    CAPTION "active OD region of the SBD.==0.22um";
