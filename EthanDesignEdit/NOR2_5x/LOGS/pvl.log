NOT _EPTMPL264741 M2 -outputlayer MOM_M2_SPACE;
CONVEX_EDGE MOM_M2_SPACE -angle1 -eq 90 -angle2 -eq 90 -outputlayer MOM_M2_SPACE_90_90;
