AND MOMDMY_3 M3 -outputlayer MOM_M3;
EDGE_BOOLEAN -coincident_only -inside M3 MOM_M3 -outputlayer MOM_M3_EDGE;
CONVEX_EDGE MOM_M3_EDGE -angle1 -eq 90 -angle2 -eq 90 -outputlayer MOM_M3_LINE_END;
EDGE_BOOLEAN -coincident_only -inside -not MOM_M3_EDGE MOM_M3_LINE_END -outputlayer MOM_M3_SIDE_EDGE;
EDGE_SELECT -coincident_only -inside M3i MOM_M3_SIDE_EDGE -outputlayer MOM_M3_SIDE_EDGE_FULL;
EDGE_SELECT -coincident_only -outside -not MOMDMY_3 M3 -outputlayer _EPTMPL264765;
EDGE_EXPAND _EPTMPL264765 -outside_by "GRID" -corner_fill -outputlayer MOM_M3_SPACE_pre;
OR MOMDMY_3 MOM_M3_SPACE_pre -outputlayer _EPTMPL264767;
NOT _EPTMPL264767 M3 -outputlayer MOM_M3_SPACE;
CONVEX_EDGE MOM_M3_SPACE -angle1 -eq 90 -angle2 -eq 90 -outputlayer MOM_M3_SPACE_90_90;
CONVEX_EDGE MOM_M3_SPACE_90_90 -angle1 -eq 90 -angle2 -eq 90 -outputlayer MOM_M3_SPACE_90_90_1;
CONVEX_EDGE MOM_M3_SPACE_90_90 -angle1 -eq 90 -angle2 -eq 0 -outputlayer MOM_M3_SPACE_90_90_2;
ENC MOM_M3_SIDE_EDGE_FULL MOM_M3_SPACE_90_90_2 -lt "GRID" -abut -eq 90 -intersecting only -output positive1 -outputlayer _EPTMPL264772;
EDGE_SELECT -coincident_only -inside MOM_M3_SIDE_EDGE_FULL _EPTMPL264772 -outputlayer _EPTMPL264773;
EDGE_BOOLEAN -coincident_only -inside MOM_M3_SIDE_EDGE _EPTMPL264773 -outputlayer LAST_M3_METAL_EDGE_pre;
OR_EDGE MOM_M3_SPACE_90_90_1 MOM_M3_SPACE_90_90_2 -outputlayer _EPTMPL264775;
EDGE_EXPAND _EPTMPL264775 -inside_by "GRID" -outputlayer _EPTMPL264776;
BBOX _EPTMPL264776 -outputlayer _EPTMPL264777;
EDGE_BOOLEAN -inside LAST_M3_METAL_EDGE_pre _EPTMPL264777 -outputlayer LAST_M3_METAL_EDGE;
EDGE_BOOLEAN -coincident_only -not MOM_M3_SPACE_90_90 MOM_M3_SPACE_90_90_1 -outputlayer MOM_M3_SPACE_90_90_3;
CONVEX_EDGE MOM_M3_SPACE -angle1 -eq 90 -angle2 -eq 270 -outputlayer MOM_M3_SPACE_90_270;
OR_EDGE MOM_M3_SPACE_90_90_3 MOM_M3_SPACE_90_270 -outputlayer _EPTMPL264781;
EDGE_EXPAND _EPTMPL264781 -inside_by "GRID" -outputlayer _EPTMPL264782;
BBOX _EPTMPL264782 -outputlayer _EPTMPL264783;
EDGE_BOOLEAN -inside MOM_M3_SIDE_EDGE _EPTMPL264783 -outputlayer MOM_M3_METAL;
EDGE_BOOLEAN -coincident_only -not MOM_M3_METAL LAST_M3_METAL_EDGE -outputlayer MOM_M3_CAP_EDGE;

RULE MOM.A.1 {
    CAPTION "Maximum sidewall area of total metals in MOM without Via <= 1.64e+15";
    DFM_PROPERTY CHIP_MOM MOM_M1_CAP_EDGE MOM_M2_CAP_EDGE MOM_M3_CAP_EDGE -overlap -nomulti [ 
 Sidewall_Area = ( LENGTH ( MOM_M1_CAP_EDGE ) *M1_THICKNESS+ LENGTH ( MOM_M2_CAP_EDGE ) *M2_THICKNESS+ LENGTH ( MOM_M3_CAP_EDGE ) *M3_THICKNESS ) / 2 
 ] -gt "MOM_A_1" -outputlayer MOM_SA;
    MERGE MOM_SA ; // -outputlayer _EPTMPL264787
    DFM_RDB MOM_SA MOM.A.1.a.rep -noempty -nopseudo;
}

RULE MOM.S.2:M1 {
    CAPTION "Space of metal (M1/Mx) line end in MOMDMY_n >= 0.5";
    EXTE MOM_M1_LINE_END M1 -lt "MOM_S_2" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264789
}

RULE MOM.S.2:M2 {
    CAPTION "Space of metal (M1/Mx) line end in MOMDMY_n >= 0.5";
    EXTE MOM_M2_LINE_END M2 -lt "MOM_S_2" -abut -lt 90 -output region ; // -outputlayer _EPTMPL264790
}

RULE MOM.R.1 {
    CAPTION "VIA in MOMDMY is not allowed.";
    AND MOMDMY_1 VIA1 ; // -outputlayer _EPTMPL264791
    AND MOMDMY_2 VIA1 ; // -outputlayer _EPTMPL264792
    AND MOMDMY_2 VIA2 ; // -outputlayer _EPTMPL264793
    AND MOMDMY_3 VIA2 ; // -outputlayer _EPTMPL264794
}

RULE DRM.R.1 {
    CAPTION "DRM.R.1 is a warning message to remind the users to check the related DRMs. Please refer to DRM.R.1 in the DRM for details.";
    COPY CHIPx ; // -outputlayer _EPTMPL264795
}
