    SELECT -enclose_rect M2_S_REG -width GRID -length M2_S_2_L -outputlayer M2_S_REG_CHECK;
    EDGE_BOOLEAN -coincident_only -outside M2_S_REG_CHECK M2_Wide -outputlayer WideEdge1;
    EDGE_BOOLEAN -coincident_only -inside M2_Small M2 -outputlayer M2_Small_Edge;
    EDGE_BOOLEAN -coincident_only -outside M2_S_REG_CHECK M2_Small_Edge -outputlayer WideEdge2;
    PATH_LENGTH WideEdge1 -ge "M2_S_2_L" ; // -outputlayer _EPTMPL262827
    PATH_LENGTH WideEdge2 -ge "M2_S_2_L" ; // -outputlayer _EPTMPL262828
}

RULE M2.S.2.1.b {
    CAPTION "Min. space between two wide metals with parallel run length >= 35 and same connection >=0.6 um";
    SHRINK M2 -right 5 -outputlayer _EPTMPL262829;
    SHRINK _EPTMPL262829 -left 5 -outputlayer _EPTMPL262830;
    SHRINK _EPTMPL262830 -top 5 -outputlayer _EPTMPL262831;
    SHRINK _EPTMPL262831 -bottom 5 -outputlayer M2_S5;
    GROW M2_S5 -right 5 -outputlayer _EPTMPL262833;
