RULE M2.A.1 {
    CAPTION "Min M2 area region < 0.202";
    AREA M2 -lt "Mx_A_1" ; // -outputlayer _EPTMPL262847
}
variable VIA_W_1 5;
variable VIA_S_1 5;
variable VIA_S_2 2.7;
variable Mx_S_3_7 1.2;
variable VIA_S_2L 15;
variable VIA_S_4 5;
variable VIA_S_5 12.7;
variable VIA_A_3 960;
variable VIA_A_3_B 2000;
variable VIA_A_2 3000;
variable VIA_A_2_B 4000;
variable VIA_A_1 4900;
variable VIA_Merge 2.505;
variable VIA_D_1 0.1;
variable VIA_S_3 0.49;
variable VIA_Filter 3;
SELECT -interact VIA1 M1 -outputlayer VIA1_M;
SIZE VIA1_M -by "VIA_S_1/2" -inside_of M1 -step 0.46 -outputlayer VIA1Merge1;
SIZE VIA1_M -by "VIA_S_1/2" -overunder -outputlayer VIA1Merge2;
AND VIA1Merge1 VIA1Merge2 -outputlayer VIA1Merge.pre1;
SELECT -enclose_rect VIA1Merge.pre1 -width VIA_S_2L -length VIA_W_1 -outputlayer VIA1Merge.pre11;
SELECT -interact VIA1_M VIA1Merge.pre11 -outputlayer VIA1Merge.pre12;
SIZE VIA1Merge.pre12 -by "VIA_S_1/2" -overunder -outputlayer VIA1Merge.pre13;
AND VIA1Merge1 VIA1Merge.pre13 -outputlayer VIA1Merge.pre2;
SIZE VIA1Merge.pre2 -by "VIA_Filter/2" -underover -outputlayer VIA1_same_array;
SIZE VIA1Merge.pre1 -by "VIA_Filter/2" -underover -outputlayer VIA1_same_array_B;
SELECT -interact VIA2 M2 -outputlayer VIA2_M;
SIZE VIA2_M -by "VIA_S_1/2" -inside_of M2 -step 0.46 -outputlayer VIA2Merge1;
SIZE VIA2_M -by "VIA_S_1/2" -overunder -outputlayer VIA2Merge2;
AND VIA2Merge1 VIA2Merge2 -outputlayer VIA2Merge.pre1;
SELECT -enclose_rect VIA2Merge.pre1 -width VIA_S_2L -length VIA_W_1 -outputlayer VIA2Merge.pre11;
